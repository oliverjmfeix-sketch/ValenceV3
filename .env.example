# Valence backend — environment variable reference.
#
# Copy this file to ../.env (one directory up from the worktree, at
# C:/Users/olive/ValenceV3/.env) and fill in real values. The shared
# .env serves both the main repo and the v4-deontic worktree.
#
# Created during Phase D Commit 0 (2026-04-28). Phase C operated
# without ANTHROPIC_API_KEY by design ("no Claude SDK calls"
# constraint); Phase D needs the key for synthesis.

# ─── TypeDB Cloud (data layer) ────────────────────────────────────────────────
# v3 reads `valence`; Phase B/C/D v4 work reads `valence_v4` (override
# TYPEDB_DATABASE per-process or set explicitly here).
TYPEDB_ADDRESS=ip654h-0.cluster.typedb.com:80
TYPEDB_DATABASE=valence
TYPEDB_USERNAME=<your-typedb-username>
TYPEDB_PASSWORD=<your-typedb-password>
TYPEDB_TLS_ENABLED=true

# ─── Anthropic API (Claude SDK) ───────────────────────────────────────────────
# Used by:
#   - app/services/extraction.py (v3 + v4 extraction; ~$5–15/run)
#   - app/services/synthesis_v4.py (Phase D synthesis; ~$0.06/question)
#   - app/scripts/smoke_test_anthropic.py (sanity check; ~$0.0001/run)
# Phase C did not need this; Phase D onward does.
ANTHROPIC_API_KEY=<your-anthropic-api-key>

# ─── Web framework (FastAPI / CORS) ───────────────────────────────────────────
# Comma-separated list of origins permitted to call the deals API in dev.
CORS_ORIGINS_STR=http://localhost:3000,http://localhost:8080

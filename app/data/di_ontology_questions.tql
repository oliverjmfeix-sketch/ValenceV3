# DI11: CAPACITY CALCULATION (8 questions)
# ═══════════════════════════════════════════════════════════════════════════════

insert $di_k1 isa ontology_question,
    has question_id "di_k1",
    has covenant_type "DI",
    has question_text "What is the total freebie/free-and-clear capacity across all baskets?",
    has answer_type "number",
    has display_order 160,
    has extraction_prompt "Calculate the total fixed-dollar debt capacity available without ratio tests. Sum the freebie basket, general basket fixed amount, and other fixed baskets. Return total USD.";

insert $di_k2 isa ontology_question,
    has question_id "di_k2",
    has covenant_type "DI",
    has question_text "How many baskets use 'grower' (greater of $ and % EBITDA) construction?",
    has answer_type "integer",
    has display_order 161,
    has extraction_prompt "Count the number of debt baskets that use a 'greater of' construction allowing capacity to grow with EBITDA.";

insert $di_k3 isa ontology_question,
    has question_id "di_k3",
    has covenant_type "DI",
    has question_text "Can freebie and ratio prong be used simultaneously (stacking)?",
    has answer_type "boolean",
    has display_order 162,
    has extraction_prompt "Determine if the freebie basket can be used at the same time as the ratio prong (in a single incurrence or concurrently), and whether freebie debt is excluded from the pro forma leverage calculation for the ratio test.";

insert $di_k4 isa ontology_question,
    has question_id "di_k4",
    has covenant_type "DI",
    has question_text "What is the maximum first lien debt capacity at closing leverage?",
    has answer_type "number",
    has display_order 163,
    has extraction_prompt "Calculate the maximum first lien secured debt capacity available assuming the borrower maintains closing date leverage. Include incremental (freebie + ratio), general basket, and other first-lien-permitted baskets.";

insert $di_k5 isa ontology_question,
    has question_id "di_k5",
    has covenant_type "DI",
    has question_text "What is the maximum total debt capacity at closing leverage?",
    has answer_type "number",
    has display_order 164,
    has extraction_prompt "Calculate the maximum total debt capacity (secured + unsecured) available assuming closing date leverage. Include all baskets.";

insert $di_k6 isa ontology_question,
    has question_id "di_k6",
    has covenant_type "DI",
    has question_text "Is there a 'ratios first' ordering for basket utilization?",
    has answer_type "boolean",
    has display_order 165,
    has extraction_prompt "Determine if debt is deemed incurred first under the ratio prong (when available) before using fixed baskets. This preserves fixed basket capacity for when ratio headroom is exhausted.";

insert $di_k7 isa ontology_question,
    has question_id "di_k7",
    has covenant_type "DI",
    has question_text "Can basket capacity be 'reloaded' by voluntary prepayment?",
    has answer_type "boolean",
    has display_order 166,
    has extraction_prompt "Determine if voluntary prepayment of debt incurred under a basket 'reloads' that basket (makes capacity available again), or if basket capacity is one-time use.";

insert $di_k8 isa ontology_question,
    has question_id "di_k8",
    has covenant_type "DI",
    has question_text "Are any baskets 'inside' others (sublimits)?",
    has answer_type "boolean",
    has display_order 167,
    has extraction_prompt "Determine if any baskets are sublimits of other baskets (shared capacity rather than additive). For example, acquisition debt as a sublimit of the general basket.";


# ═══════════════════════════════════════════════════════════════════════════════
# DI12: VULNERABILITIES (10 questions)
# ═══════════════════════════════════════════════════════════════════════════════

insert $di_l1 isa ontology_question,
    has question_id "di_l1",
    has covenant_type "DI",
    has question_text "Is there a trapdoor basket (unlimited ratio debt with no dollar cap)?",
    has answer_type "boolean",
    has display_order 170,
    has extraction_prompt "VULNERABILITY: Determine if there is a ratio debt basket that permits unlimited debt when a leverage test is met, with NO dollar cap even when the ratio is satisfied. This is a 'trapdoor' that can allow massive debt incurrence.";

insert $di_l2 isa ontology_question,
    has question_id "di_l2",
    has covenant_type "DI",
    has question_text "Can IED be incurred without triggering MFN (priming risk)?",
    has answer_type "boolean",
    has display_order 171,
    has extraction_prompt "VULNERABILITY: Determine if Incremental Equivalent Debt can be incurred without triggering MFN pricing protection. If yes, borrower can incur pari passu debt at higher yields, effectively 'priming' existing lenders without compensation.";

insert $di_l3 isa ontology_question,
    has question_id "di_l3",
    has covenant_type "DI",
    has question_text "Is freebie basket stacking with ratio prong permitted?",
    has answer_type "boolean",
    has display_order 172,
    has extraction_prompt "VULNERABILITY: Determine if the freebie basket is excluded from pro forma leverage calculations, allowing it to be 'stacked' with the ratio prong. This significantly increases effective debt capacity beyond headline ratios.";

insert $di_l4 isa ontology_question,
    has question_id "di_l4",
    has covenant_type "DI",
    has question_text "Is unlimited automatic reclassification permitted (perpetual refresh)?",
    has answer_type "boolean",
    has display_order 173,
    has extraction_prompt "VULNERABILITY: Determine if unlimited automatic reclassification from freebie to ratio basket is permitted. This allows perpetual 'refreshing' of freebie capacity whenever leverage improves.";

insert $di_l5 isa ontology_question,
    has question_id "di_l5",
    has covenant_type "DI",
    has question_text "Has the MFN sunset period expired (based on deal age)?",
    has answer_type "boolean",
    has display_order 174,
    has extraction_prompt "VULNERABILITY: Based on the closing date and MFN sunset period, has MFN protection expired? If yes, new incremental debt can be priced without limit.";

insert $di_l6 isa ontology_question,
    has question_id "di_l6",
    has covenant_type "DI",
    has question_text "Can multiple baskets be used for the same debt (basket arbitrage)?",
    has answer_type "boolean",
    has display_order 175,
    has extraction_prompt "VULNERABILITY: Determine if the same debt can be attributed to multiple baskets, or if debt can be shifted between baskets opportunistically. This creates 'basket arbitrage' opportunities.";

insert $di_l7 isa ontology_question,
    has question_id "di_l7",
    has covenant_type "DI",
    has question_text "Is there intercompany debt leakage risk (to non-guarantor subs)?",
    has answer_type "boolean",
    has display_order 176,
    has extraction_prompt "VULNERABILITY: Determine if intercompany debt can flow from Loan Parties to non-guarantor subsidiaries without subordination, creating value leakage risk.";

insert $di_l8 isa ontology_question,
    has question_id "di_l8",
    has covenant_type "DI",
    has question_text "Can non-guarantor subsidiaries incur structurally senior secured debt?",
    has answer_type "boolean",
    has display_order 177,
    has extraction_prompt "VULNERABILITY: Determine if non-guarantor restricted subsidiaries can incur secured debt, creating structurally senior obligations that get paid before Credit Agreement debt in a liquidation.";

insert $di_l9 isa ontology_question,
    has question_id "di_l9",
    has covenant_type "DI",
    has question_text "Is the 'no worse' test available for incurrence (even above threshold)?",
    has answer_type "boolean",
    has display_order 178,
    has extraction_prompt "VULNERABILITY: Determine if debt can be incurred under a 'no worse' test — permitted if pro forma leverage is no worse than before incurrence, even if above the stated threshold. Eliminates meaningful leverage ceiling.";

insert $di_l10 isa ontology_question,
    has question_id "di_l10",
    has covenant_type "DI",
    has question_text "Overall DI vulnerability assessment (analyst notes)",
    has answer_type "string",
    has display_order 179,
    has extraction_prompt "Based on all DI analysis, provide a brief narrative summary of the key credit concerns and vulnerabilities in the debt incurrence covenant. Identify the most significant risks to lenders.";



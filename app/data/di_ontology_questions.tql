# DI8: RECLASSIFICATION (8 questions)
# ═══════════════════════════════════════════════════════════════════════════════

insert $di_h1 isa ontology_question,
    has question_id "di_h1",
    has covenant_type "DI",
    has question_text "Is reclassification of debt between baskets permitted?",
    has answer_type "boolean",
    has display_order 130,
    has extraction_prompt "Determine if the borrower can reclassify or redesignate debt from one basket to another (e.g., from freebie to ratio basket). This allows 'refreshing' basket capacity. Look for 'reclassification', 'redesignation', or 'deemed incurred under' language.";

insert $di_h2 isa ontology_question,
    has question_id "di_h2",
    has covenant_type "DI",
    has question_text "Is reclassification automatic or elective?",
    has answer_type "string",
    has display_order 131,
    has extraction_prompt "If reclassification is permitted, is it automatic (happens whenever conditions are met) or elective (borrower must choose)? Return 'automatic', 'elective', or 'both'.";

insert $di_h3 isa ontology_question,
    has question_id "di_h3",
    has covenant_type "DI",
    has question_text "Can freebie basket be refreshed by reclassifying to ratio basket?",
    has answer_type "boolean",
    has display_order 132,
    has extraction_prompt "Determine if debt incurred under the freebie basket can be reclassified as ratio debt (when ratio headroom exists), thereby refreshing the freebie basket for future use. This is a significant flexibility.";

insert $di_h4 isa ontology_question,
    has question_id "di_h4",
    has covenant_type "DI",
    has question_text "Can reclassification occur in either direction (freebie↔ratio)?",
    has answer_type "boolean",
    has display_order 133,
    has extraction_prompt "Determine if reclassification is bidirectional — can debt be moved from freebie to ratio AND from ratio to freebie? One-way (freebie→ratio only) is more common.";

insert $di_h5 isa ontology_question,
    has question_id "di_h5",
    has covenant_type "DI",
    has question_text "Does reclassified debt still trigger MFN?",
    has answer_type "boolean",
    has display_order 134,
    has extraction_prompt "If debt is reclassified from freebie (MFN-exempt) to ratio basket, does the original MFN exemption persist or does reclassified debt become subject to MFN?";

insert $di_h6 isa ontology_question,
    has question_id "di_h6",
    has covenant_type "DI",
    has question_text "Is notice to Agent required for reclassification?",
    has answer_type "boolean",
    has display_order 135,
    has extraction_prompt "Determine if the borrower must notify the Administrative Agent when reclassifying debt between baskets.";

insert $di_h7 isa ontology_question,
    has question_id "di_h7",
    has covenant_type "DI",
    has question_text "Can debt be split between multiple baskets simultaneously?",
    has answer_type "boolean",
    has display_order 136,
    has extraction_prompt "Determine if a single debt incurrence can be split across multiple baskets (e.g., partly under freebie, partly under ratio) or must be attributed to a single basket.";

insert $di_h8 isa ontology_question,
    has question_id "di_h8",
    has covenant_type "DI",
    has question_text "Is there a limit on number of reclassifications?",
    has answer_type "boolean",
    has display_order 137,
    has extraction_prompt "Determine if there is any limit on how many times debt can be reclassified, or if reclassification is unlimited.";



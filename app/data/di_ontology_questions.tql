    has extraction_prompt "Determine if the weighted average life of incremental debt must be no shorter than the remaining WAL of existing term loans.";

insert $di_g7 isa ontology_question,
    has question_id "di_g7",
    has covenant_type "DI",
    has question_text "Is scheduled amortization permitted on incremental/ratio debt?",
    has answer_type "boolean",
    has display_order 126,
    has extraction_prompt "Determine if scheduled amortization is permitted on incremental or ratio debt prior to maturity. Standard is no amortization or limited to 1% annually.";

insert $di_g8 isa ontology_question,
    has question_id "di_g8",
    has covenant_type "DI",
    has question_text "Must collateral be same or subset of existing collateral?",
    has answer_type "boolean",
    has display_order 127,
    has extraction_prompt "Determine if incremental or ratio debt must be secured by the same collateral as existing debt, or a subset thereof (cannot have broader collateral coverage).";

insert $di_g9 isa ontology_question,
    has question_id "di_g9",
    has covenant_type "DI",
    has question_text "Must guarantors be same or subset of existing guarantors?",
    has answer_type "boolean",
    has display_order 128,
    has extraction_prompt "Determine if incremental or ratio debt must be guaranteed by the same guarantors as existing debt, or a subset thereof (cannot have additional guarantors).";

insert $di_g10 isa ontology_question,
    has question_id "di_g10",
    has covenant_type "DI",
    has question_text "Is currency matching required (same currency or hedged)?",
    has answer_type "boolean",

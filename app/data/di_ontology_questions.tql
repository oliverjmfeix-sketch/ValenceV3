    has extraction_prompt "Determine if there are any circumstances where secured debt can be incurred under a debt basket without needing to use a corresponding lien basket (e.g., automatically permitted liens).";

insert $di_i6 isa ontology_question,
    has question_id "di_i6",
    has covenant_type "DI",
    has question_text "What is the aggregate secured debt lien cap (if separate from debt)?",
    has answer_type "number",
    has display_order 145,
    has extraction_prompt "If there is a separate aggregate cap on liens securing indebtedness (distinct from individual basket caps), extract that cap.";

insert $di_i7 isa ontology_question,

# DI10: CROSS-COVENANT LINKS (8 questions)
# ═══════════════════════════════════════════════════════════════════════════════

insert $di_j1 isa ontology_question,
    has question_id "di_j1",
    has covenant_type "DI",
    has question_text "Does contribution debt increase the RP builder basket (Available Amount)?",
    has answer_type "boolean",
    has display_order 150,
    has extraction_prompt "Determine if equity contributions that can be used for contribution debt ALSO increase the Cumulative Amount / Available Amount for the RP builder basket. This creates dual use of the same equity.";

insert $di_j2 isa ontology_question,
    has question_id "di_j2",
    has covenant_type "DI",
    has question_text "Is the contribution debt / builder basket link dollar-for-dollar?",
    has answer_type "boolean",
    has display_order 151,
    has extraction_prompt "If contribution debt increases the builder basket, is it dollar-for-dollar (1:1) or some other ratio?";

insert $di_j3 isa ontology_question,
    has question_id "di_j3",
    has covenant_type "DI",
    has question_text "Can RP capacity be converted to debt capacity ('Available RP Amount' debt basket)?",
    has answer_type "boolean",
    has display_order 152,
    has extraction_prompt "Determine if there is an 'Available RP Capacity Amount' debt basket that converts restricted payment capacity into debt incurrence capacity. Very aggressive; allows dividend capacity to fund additional debt.";

insert $di_j4 isa ontology_question,
    has question_id "di_j4",
    has covenant_type "DI",
    has question_text "Does asset sale mandatory prepayment reload incremental capacity?",
    has answer_type "boolean",
    has display_order 153,
    has extraction_prompt "Determine if mandatory prepayment of term loans from asset sale proceeds reloads the prepayments prong of incremental capacity (similar to voluntary prepayments).";

insert $di_j5 isa ontology_question,
    has question_id "di_j5",
    has covenant_type "DI",
    has question_text "Can Unrestricted Subsidiaries incur unlimited debt?",
    has answer_type "boolean",
    has display_order 154,
    has extraction_prompt "Determine if Unrestricted Subsidiaries are entirely excluded from the debt covenant restrictions (can incur unlimited debt). Standard, but leakage risk if assets can be moved to Unrestricted Subs.";

insert $di_j6 isa ontology_question,
    has question_id "di_j6",
    has covenant_type "DI",
    has question_text "Can Restricted Subsidiaries be redesignated as Unrestricted to avoid debt limits?",
    has answer_type "boolean",
    has display_order 155,
    has extraction_prompt "Determine if Restricted Subsidiaries can be redesignated as Unrestricted Subsidiaries (subject to Investment basket capacity), thereby escaping debt covenant restrictions.";

insert $di_j7 isa ontology_question,
    has question_id "di_j7",
    has covenant_type "DI",
    has question_text "Does debt repayment from the builder basket increase any debt basket capacity?",
    has answer_type "boolean",
    has display_order 156,
    has extraction_prompt "Determine if using the RP builder basket to repay debt (Restricted Debt Payments) increases debt incurrence capacity in a circular manner.";

insert $di_j8 isa ontology_question,
    has question_id "di_j8",
    has covenant_type "DI",
    has question_text "Are there cross-references allowing basket 'sharing' between covenants?",
    has answer_type "boolean",
    has display_order 157,
    has extraction_prompt "Determine if there are cross-references between covenants allowing capacity from one basket to be used for another covenant's purposes (e.g., Investment basket capacity usable for RDP).";



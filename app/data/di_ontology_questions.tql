    has answer_type "boolean",
    has display_order 140,
    has extraction_prompt "Determine if there is a corresponding basket in the Liens covenant (Section 6.02 or similar) that permits liens to secure incremental debt. Typically yes.";

insert $di_i2 isa ontology_question,
    has question_id "di_i2",
    has covenant_type "DI",
    has question_text "Does ratio debt have a corresponding lien basket?",
    has answer_type "boolean",
    has display_order 141,
    has extraction_prompt "Determine if there is a lien basket permitting liens to secure ratio debt.";

insert $di_i3 isa ontology_question,
    has question_id "di_i3",
    has covenant_type "DI",
    has question_text "Does the general debt basket have a corresponding lien basket?",
    has answer_type "boolean",
    has display_order 142,
    has extraction_prompt "Determine if there is a lien basket permitting liens to secure general basket debt.";

insert $di_i4 isa ontology_question,
    has question_id "di_i4",
    has covenant_type "DI",
    has question_text "Is debt basket capacity shared with lien basket capacity?",
    has answer_type "boolean",
    has display_order 143,
    has extraction_prompt "Determine if debt basket caps are shared with corresponding lien basket caps, or if they are separate (additive). Shared is more lender-protective.";

insert $di_i5 isa ontology_question,
    has question_id "di_i5",
    has covenant_type "DI",
    has question_text "Can secured debt be incurred without using a specific lien basket?",
    has answer_type "boolean",

    has covenant_type "DI",
    has question_text "What section contains the liens covenant?",
    has answer_type "string",
    has display_order 146,
    has extraction_prompt "Extract the section reference for the liens negative covenant in THIS document.";

insert $di_i8 isa ontology_question,
    has question_id "di_i8",

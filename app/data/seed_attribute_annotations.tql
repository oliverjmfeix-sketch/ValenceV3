# ═══════════════════════════════════════════════════════════════════════════════
# ATTRIBUTE ANNOTATIONS (replaces attribute_glossary.py)
#
# Maps ontology questions to the Channel 3 entity attributes they annotate.
# graph_reader queries these at startup to build the → annotation cache.
# ═══════════════════════════════════════════════════════════════════════════════

# ── Ratio Basket ────────────────────────────────────────────────────────────
match $q isa ontology_question, has question_id "rp_g2";
insert (question: $q) isa question_annotates_attribute,
    has target_entity_type "ratio_basket",
    has target_attribute_name "ratio_threshold";

match $q isa ontology_question, has question_id "rp_g4";
insert (question: $q) isa question_annotates_attribute,
    has target_entity_type "ratio_basket",
    has target_attribute_name "is_unlimited_if_met";

match $q isa ontology_question, has question_id "rp_g5";
insert (question: $q) isa question_annotates_attribute,
    has target_entity_type "ratio_basket",
    has target_attribute_name "has_no_worse_test";

match $q isa ontology_question, has question_id "rp_g6";
insert (question: $q) isa question_annotates_attribute,
    has target_entity_type "ratio_basket",
    has target_attribute_name "no_worse_is_uncapped";


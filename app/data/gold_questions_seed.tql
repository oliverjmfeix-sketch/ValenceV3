    has deal_id "6e76ed06";

$q_rp_q4 isa gold_question,
    has question_id "duck_creek_rp_q4",
    has question_text "Which baskets can be reallocated for restricted payments?",
    has covenant_type "rp",
    has deal_id "6e76ed06";

$q_rp_q5 isa gold_question,
    has question_id "duck_creek_rp_q5",
    has question_text "What is the size of the general RP basket?",
    has covenant_type "rp",
    has deal_id "6e76ed06";

$q_rp_q6 isa gold_question,
    has question_id "duck_creek_rp_q6",
    has question_text "What are the limits on management/employee equity repurchases for restricted payments?",
    has covenant_type "rp",
    has deal_id "6e76ed06";

$q_rp_q7 isa gold_question,
    has question_id "duck_creek_rp_q7",

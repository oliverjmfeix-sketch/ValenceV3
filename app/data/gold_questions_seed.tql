    has covenant_type "rp",
    has deal_id "6e76ed06";

$q_rp_q8 isa gold_question,
    has question_id "duck_creek_rp_q8",
    has question_text "Can asset sale proceeds be used for restricted payments?",
    has covenant_type "rp",
    has deal_id "6e76ed06";

$q_rp_q9 isa gold_question,
    has question_id "duck_creek_rp_q9",
    has question_text "Is the Borrower permitted to dividend the equity it owns in Unrestricted Subsidiaries?",
    has covenant_type "rp",
    has deal_id "6e76ed06";

$q_rp_q10 isa gold_question,

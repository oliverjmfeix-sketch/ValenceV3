# ═══════════════════════════════════════════════════════════════════════════════
# DEBT INCURRENCE QUESTION → ENTITY ATTRIBUTE ANNOTATIONS
# ═══════════════════════════════════════════════════════════════════════════════
#
# Routes scalar questions to entity attributes for the extraction pipeline.
# Pattern: question_annotates_attribute relation links question_id to
# (target_entity_type, target_attribute_name) pair.
#
# The extraction pipeline uses these annotations to:
# 1. Create single-instance entities when _exists questions return true
# 2. Populate entity attributes from scalar question answers
# 3. Route multiselect answers to boolean flags on entities
#
# ═══════════════════════════════════════════════════════════════════════════════


# ═══════════════════════════════════════════════════════════════════════════════
# DI1: CORE STRUCTURE → di_provision
# ═══════════════════════════════════════════════════════════════════════════════

# di_a1: "Does a debt incurrence negative covenant exist?"
match $q isa ontology_question, has question_id "di_a1";
insert (question: $q) isa question_annotates_attribute,
    has target_entity_type "di_provision",
    has target_attribute_name "di_covenant_exists";

# di_a2: "What is the section reference for the debt incurrence covenant?"
match $q isa ontology_question, has question_id "di_a2";
insert (question: $q) isa question_annotates_attribute,
    has target_entity_type "di_provision",
    has target_attribute_name "section_reference";

# di_a3: "Does the covenant bind the Borrower?"
match $q isa ontology_question, has question_id "di_a3";
insert (question: $q) isa question_annotates_attribute,
    has target_entity_type "di_provision",
    has target_attribute_name "binds_borrower";

# di_a4: "Does the covenant bind Guarantors?"
match $q isa ontology_question, has question_id "di_a4";
insert (question: $q) isa question_annotates_attribute,
    has target_entity_type "di_provision",
    has target_attribute_name "binds_guarantors";

# di_a5: "Does the covenant bind all Restricted Subsidiaries?"
match $q isa ontology_question, has question_id "di_a5";
insert (question: $q) isa question_annotates_attribute,
    has target_entity_type "di_provision",
    has target_attribute_name "binds_restricted_subs";

# di_a6: "Is there a separate covenant for secured debt incurrence?"
match $q isa ontology_question, has question_id "di_a6";
insert (question: $q) isa question_annotates_attribute,
    has target_entity_type "di_provision",
    has target_attribute_name "has_separate_secured_covenant";

# di_a7: "Is the definition of 'Indebtedness' broad?"
match $q isa ontology_question, has question_id "di_a7";
insert (question: $q) isa question_annotates_attribute,
    has target_entity_type "di_provision",
    has target_attribute_name "indebtedness_definition_broad";


# ═══════════════════════════════════════════════════════════════════════════════
# DI2: INCREMENTAL FACILITY → incremental_facility
# ═══════════════════════════════════════════════════════════════════════════════

# di_b0: "Does the agreement include an incremental facility provision?"
match $q isa ontology_question, has question_id "di_b0";
insert (question: $q) isa question_annotates_attribute,
    has target_entity_type "incremental_facility",
    has target_attribute_name "_exists";

# di_b1: "What is the section reference for the incremental facility?"
match $q isa ontology_question, has question_id "di_b1";
insert (question: $q) isa question_annotates_attribute,
    has target_entity_type "incremental_facility",
    has target_attribute_name "section_reference";

# di_b2: "What is the free-and-clear (freebie) amount in USD?"

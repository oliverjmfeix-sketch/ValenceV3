insert (question: $q) isa question_annotates_attribute,
    has target_entity_type "incremental_facility",
    has target_attribute_name "requires_wal_parity";

# di_b18: "Is scheduled amortization prohibited on incremental?"
match $q isa ontology_question, has question_id "di_b18";
insert (question: $q) isa question_annotates_attribute,
    has target_entity_type "incremental_facility",
    has target_attribute_name "amortization_prohibited";

# di_b19: "Must incremental covenants be no more restrictive than existing?"

insert (question: $q) isa question_annotates_attribute,
    has target_entity_type "incremental_facility",
    has target_attribute_name "free_and_clear_is_grower";

# di_b5: "Does a prepayments prong exist (dry powder)?"
match $q isa ontology_question, has question_id "di_b5";
insert (question: $q) isa question_annotates_attribute,
    has target_entity_type "incremental_facility",
    has target_attribute_name "prepayments_prong_exists";

# di_b6: "Does the prepayments prong include prepayment of junior lien debt?"
match $q isa ontology_question, has question_id "di_b6";
insert (question: $q) isa question_annotates_attribute,
    has target_entity_type "incremental_facility",
    has target_attribute_name "prepayments_includes_junior";

# di_b7: "Does the prepayments prong include debt buybacks?"

insert (question: $q) isa question_annotates_attribute,
    has target_entity_type "incremental_facility",
    has target_attribute_name "ratio_prong_exists";

# di_b9: "What is the leverage threshold for the ratio prong (first lien)?"
match $q isa ontology_question, has question_id "di_b9";
insert (question: $q) isa question_annotates_attribute,
    has target_entity_type "incremental_facility",
    has target_attribute_name "ratio_prong_first_lien_threshold";

# di_b10: "What is the leverage threshold for the ratio prong (total)?"
match $q isa ontology_question, has question_id "di_b10";
insert (question: $q) isa question_annotates_attribute,
    has target_entity_type "incremental_facility",
    has target_attribute_name "ratio_prong_total_threshold";

# di_b11: "Is the ratio prong truly unlimited (no dollar cap when ratio met)?"
match $q isa ontology_question, has question_id "di_b11";
insert (question: $q) isa question_annotates_attribute,
    has target_entity_type "incremental_facility",
    has target_attribute_name "ratio_prong_unlimited";

# di_b12: "Can the general debt basket be added to incremental capacity?"
match $q isa ontology_question, has question_id "di_b12";
insert (question: $q) isa question_annotates_attribute,
    has target_entity_type "incremental_facility",
    has target_attribute_name "general_basket_addable";

# di_b13: "Is the freebie excluded from pro forma ratio calculation?"
match $q isa ontology_question, has question_id "di_b13";
insert (question: $q) isa question_annotates_attribute,
    has target_entity_type "incremental_facility",
    has target_attribute_name "freebie_excluded_from_ratio";

# di_b14: "Does incremental require no Default or Event of Default?"
match $q isa ontology_question, has question_id "di_b14";
insert (question: $q) isa question_annotates_attribute,
    has target_entity_type "incremental_facility",
    has target_attribute_name "requires_no_default";

# di_b15: "Does incremental require only no Event of Default (not Defaults)?"
match $q isa ontology_question, has question_id "di_b15";
insert (question: $q) isa question_annotates_attribute,
    has target_entity_type "incremental_facility",
    has target_attribute_name "requires_no_eod_only";

# di_b16: "Can incremental mature inside the existing term loan maturity?"

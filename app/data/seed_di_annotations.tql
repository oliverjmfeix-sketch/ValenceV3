insert (question: $q) isa question_annotates_attribute,
    has target_entity_type "incremental_facility",
    has target_attribute_name "agent_consent_nurd";

# di_b23: "Is there a minimum tranche size for incremental?"
match $q isa ontology_question, has question_id "di_b23";
insert (question: $q) isa question_annotates_attribute,
    has target_entity_type "incremental_facility",
    has target_attribute_name "minimum_tranche_size";

# di_b24: "Can existing lenders be required to participate in incremental?"
match $q isa ontology_question, has question_id "di_b24";
insert (question: $q) isa question_annotates_attribute,
    has target_entity_type "incremental_facility",

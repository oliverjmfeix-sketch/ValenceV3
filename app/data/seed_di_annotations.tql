insert (question: $q) isa question_annotates_attribute,
    has target_entity_type "incremental_facility",
    has target_attribute_name "ied_shares_cap";

# di_d3: "Does IED trigger MFN protection?" (CRITICAL)
match $q isa ontology_question, has question_id "di_d3";
insert (question: $q) isa question_annotates_attribute,
    has target_entity_type "incremental_facility",
    has target_attribute_name "ied_triggers_mfn";

# di_d4: "Does IED require an acceptable intercreditor agreement?"
match $q isa ontology_question, has question_id "di_d4";
insert (question: $q) isa question_annotates_attribute,
    has target_entity_type "incremental_facility",
    has target_attribute_name "ied_requires_intercreditor";

# di_d5: "What forms of IED are permitted?"
match $q isa ontology_question, has question_id "di_d5";
insert (question: $q) isa question_annotates_attribute,
    has target_entity_type "incremental_facility",
    has target_attribute_name "ied_permitted_forms";

# di_d6: "Must IED have maturity no earlier than existing term loans?"
match $q isa ontology_question, has question_id "di_d6";
insert (question: $q) isa question_annotates_attribute,
    has target_entity_type "incremental_facility",
    has target_attribute_name "ied_maturity_restriction";

# di_d7: "Must IED covenants be no more restrictive?"
match $q isa ontology_question, has question_id "di_d7";
insert (question: $q) isa question_annotates_attribute,
    has target_entity_type "incremental_facility",
    has target_attribute_name "ied_covenant_parity";

# di_d8: "Can IED be incurred by Borrower only, or also by Guarantors?"
match $q isa ontology_question, has question_id "di_d8";
insert (question: $q) isa question_annotates_attribute,
    has target_entity_type "incremental_facility",
    has target_attribute_name "ied_permitted_incurrors";

# di_d9: "Is junior lien IED permitted?"
match $q isa ontology_question, has question_id "di_d9";
insert (question: $q) isa question_annotates_attribute,
    has target_entity_type "incremental_facility",
    has target_attribute_name "ied_junior_lien_permitted";

# di_d10: "Is unsecured IED permitted?"
match $q isa ontology_question, has question_id "di_d10";
insert (question: $q) isa question_annotates_attribute,
    has target_entity_type "incremental_facility",
    has target_attribute_name "ied_unsecured_permitted";



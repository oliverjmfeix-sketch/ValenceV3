    has target_attribute_name "mfn_includes_upfront_fees";

# di_c14: "Are arrangement/structuring fees excluded from yield calculation?"
match $q isa ontology_question, has question_id "di_c14";
insert (question: $q) isa question_annotates_attribute,
    has target_entity_type "incremental_facility",
    has target_attribute_name "mfn_excludes_arranger_fees";

# di_c15: "Does a de minimis amount of incremental avoid MFN?"

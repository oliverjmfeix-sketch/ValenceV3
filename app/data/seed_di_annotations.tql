# ═══════════════════════════════════════════════════════════════════════════════
# DI4: IED & SIDECAR → incremental_facility
# ═══════════════════════════════════════════════════════════════════════════════

# di_d1: "Is Incremental Equivalent Debt (IED) permitted?"
match $q isa ontology_question, has question_id "di_d1";

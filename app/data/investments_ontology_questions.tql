# ═══════════════════════════════════════════════════════════════════════════════
# OVERFLOW QUESTIONS: INV5 e11-e13, INV6 f11, INV3 c11-c13
# ═══════════════════════════════════════════════════════════════════════════════
# The 1140-block (INV5) and 1120-block (INV3) filled to 10 questions each; the
# 1150-block (INV6) filled to 7 questions. These overflow questions belong to
# categories INV3, INV5, and INV6 but use display_order slots in the INV8 tail
# (1175-1178) and the post-INV11 tail (1195-1197). display_order is UI-only and
# does not bind file layout; category linkage (below in this section) correctly
# ties each overflow question to its owning category.
# ═══════════════════════════════════════════════════════════════════════════════

insert $inv_e11 isa ontology_question,
    has question_id "inv_e11",
    has covenant_type "INV",
    has question_text "What is the dollar-cap backstop on the ratio investment basket (USD), if any?",
    has answer_type "number",
    has display_order 1175,
    has extraction_prompt "Extract the dollar-cap backstop on the ratio investment basket, in US dollars, where such a backstop exists. Look for basket language such as 'so long as [ratio test] is met and not to exceed $X million in the aggregate'. Return the cap as a full integer (e.g., 250000000 for $250 million). Return null if the ratio investment basket has no dollar backstop — uncapped when ratio-compliant (inv_e3 captures whether ANY cap exists as a boolean; this question captures the value when one is present) — or if no ratio investment basket exists.";
# TODO-ENG: add inv_provision.ratio_basket_backstop_cap_usd double

insert $inv_e12 isa ontology_question,
    has question_id "inv_e12",
    has covenant_type "INV",
    has question_text "Does the ratio investment basket track capacity on an OUTSTANDING basis (refreshes on return)?",
    has answer_type "boolean",
    has display_order 1176,
    has extraction_prompt "Determine whether basket capacity under the ratio investment basket is reduced (made available again) when the Loan Parties receive a return ON or return OF that Investment — e.g., a dividend received in cash, proceeds from sale of the investment, or repayment of an intercompany loan. Look for language such as 'the aggregate amount of Investments outstanding at any time under this clause' (outstanding-basis) versus 'the aggregate amount of Investments made under this clause' (cumulative / gross basis). Answer true if the basket is tracked on a NET / OUTSTANDING basis. Answer false if the basket consumes capacity cumulatively — each Investment permanently reduces available capacity regardless of subsequent returns.";
# TODO-ENG: add inv_provision.ratio_basket_outstanding_basis boolean

insert $inv_e13 isa ontology_question,
    has question_id "inv_e13",
    has covenant_type "INV",
    has question_text "Does the ratio investment basket also condition on a coverage ratio (FCCR / ICR)?",
    has answer_type "boolean",
    has display_order 1177,
    has extraction_prompt "Determine whether the ratio investment basket conditions on a COVERAGE ratio (e.g., Fixed Charge Coverage Ratio, Interest Coverage Ratio) alongside or instead of a leverage ratio. Look for language such as 'provided that the Fixed Charge Coverage Ratio is at least Y.YY to 1.00' as a condition on this basket. Answer true if any coverage-ratio variant applies to this basket. Answer false if the basket uses only leverage-ratio tests — the more common structure.";
# TODO-ENG: add inv_provision.ratio_basket_has_coverage_ratio boolean

insert $inv_f11 isa ontology_question,
    has question_id "inv_f11",
    has covenant_type "INV",
    has question_text "Does the existing-investments grandfather permit upsizes above the scheduled amounts?",
    has answer_type "boolean",
    has display_order 1178,
    has extraction_prompt "Determine whether the Permitted Investments list's existing-investments grandfather carve-out permits the Loan Parties to UPSIZE existing-scheduled Investments above the amounts listed on the disclosure schedule (inv_f10 captures the schedule reference). Look for language such as 'Investments existing on the Closing Date and listed on Schedule [X] (and any increase, extension, or modification thereof)' (permits upsize) versus strict 'Investments existing on the Closing Date and listed on Schedule [X] in the amounts set forth therein' (no upsize). Answer true if upsizes are permitted — a structural gap that lets scheduled investments balloon under the grandfather. Answer false if the carve-out is limited to the exact amounts listed on the schedule.";
# TODO-ENG: add inv_provision.existing_investments_upsize_permitted boolean

insert $inv_c11 isa ontology_question,
    has question_id "inv_c11",
    has covenant_type "INV",
    has question_text "Does the Unrestricted Sub investment basket track capacity on an OUTSTANDING basis (refreshes on return)?",
    has answer_type "boolean",
    has display_order 1195,
    has extraction_prompt "Determine whether basket capacity under the Unrestricted Subsidiary investment basket is reduced (made available again) when the Loan Parties receive a return on or return of that Investment — e.g., a dividend paid by the unsub to a Loan Party, proceeds from sale of the unsub, or repayment of an intercompany loan. Look for language such as 'the aggregate amount of Investments outstanding at any time under this clause' (outstanding-basis) versus 'the aggregate amount of Investments made under this clause' (cumulative / gross basis). Answer true if the basket is tracked on a NET / OUTSTANDING basis — permits cycling capital through unsubs. Answer false if the basket consumes capacity cumulatively — each investment permanently reduces available capacity regardless of subsequent returns.";
# TODO-ENG: add inv_provision.unsub_basket_outstanding_basis boolean

insert $inv_c12 isa ontology_question,
    has question_id "inv_c12",
    has covenant_type "INV",
    has question_text "Is there a timing / blackout restriction on Material IP contributions to Unrestricted Subsidiaries?",
    has answer_type "boolean",
    has display_order 1196,
    has extraction_prompt "Determine whether the investments covenant imposes a timing restriction on Material Intellectual Property contributions to Unrestricted Subsidiaries — e.g., a blackout period following an Event of Default, a distressed-condition test, or a specified triggering event. Look for language such as 'no Material Intellectual Property may be contributed to any Unrestricted Subsidiary during the [N]-month period following any Default or Event of Default', or 'no such contribution permitted if Total Net Leverage Ratio exceeds X.XXx'. Answer true if any such timing or condition-based restriction applies. Answer false if Material IP contributions to Unsubs are not subject to timing or state-based restrictions.";
# TODO-ENG: add inv_provision.ip_contribution_timing_restriction boolean

insert $inv_c13 isa ontology_question,
    has question_id "inv_c13",
    has covenant_type "INV",
    has question_text "Must contributed Material IP to Unrestricted Subs be valued by independent appraisal?",
    has answer_type "boolean",
    has display_order 1197,
    has extraction_prompt "Determine whether the investments covenant requires independent third-party appraisal of Material Intellectual Property contributed to an Unrestricted Subsidiary — for purposes of calculating basket consumption. Look for language such as 'the fair market value of any Material Intellectual Property so contributed shall be determined by an independent appraisal' versus 'as reasonably determined in good faith by the Borrower'. Answer true if independent appraisal is required (credit-friendly — prevents Borrower-side under-valuation that would consume less basket capacity than appropriate). Answer false if FMV can be determined solely by the Borrower's good-faith judgment.";
# TODO-ENG: add inv_provision.ip_contribution_requires_independent_appraisal boolean


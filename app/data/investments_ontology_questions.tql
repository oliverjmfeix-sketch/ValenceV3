insert (category: $cat, question: $q) isa category_has_question;
match $cat isa ontology_category, has category_id "INV6"; $q isa ontology_question, has question_id "inv_f11";
insert (category: $cat, question: $q) isa category_has_question;
match $cat isa ontology_category, has category_id "INV3"; $q isa ontology_question, has question_id "inv_c11";
insert (category: $cat, question: $q) isa category_has_question;
match $cat isa ontology_category, has category_id "INV3"; $q isa ontology_question, has question_id "inv_c12";
insert (category: $cat, question: $q) isa category_has_question;

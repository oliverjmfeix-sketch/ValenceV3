# ═══════════════════════════════════════════════════════════════════════════════
# INV11: POST-INVESTMENT MECHANICS (5 questions)
# ═══════════════════════════════════════════════════════════════════════════════

insert $inv_k1 isa ontology_question,
    has question_id "inv_k1",
    has covenant_type "INV",
    has question_text "Are long-tenor loan Investments automatically reclassified as Indebtedness (DI covenant)?",
    has answer_type "boolean",
    has display_order 1190,
    has extraction_prompt "Determine whether the investments covenant reclassifies Investment-loans as Indebtedness (for DI-covenant purposes) if the loan remains outstanding beyond a threshold period — e.g., a 1-year note that rolls over indefinitely effectively becomes perpetual financing. Look for language addressing this edge case, such as 'any Investment consisting of a loan with a maturity (including any extensions) exceeding [N] years shall be treated as Indebtedness rather than an Investment for all purposes of this Agreement'. Answer true if such an automatic reclassification applies. Answer false if loan Investments remain classified as Investments regardless of tenor — which permits indefinite intercompany financing to escape the DI covenant's scope.";
# TODO-ENG: add inv_provision.long_tenor_loan_reclassified_as_debt boolean

insert $inv_k2 isa ontology_question,
    has question_id "inv_k2",
    has covenant_type "INV",
    has question_text "Does an acquired entity becoming a Restricted Subsidiary release basket capacity consumed?",
    has answer_type "boolean",
    has display_order 1191,
    has extraction_prompt "Determine whether investment-basket capacity consumed for an Investment in a Person (e.g., acquisition target, non-guarantor Restricted Subsidiary, Unrestricted Subsidiary) is RELEASED — made available again — when that Person later becomes a Restricted Subsidiary and Loan Party. Look for language such as 'basket capacity consumed for any Investment shall be restored if and when the Person in which such Investment was made becomes a Restricted Subsidiary Loan Party'. Answer true if such a release exists — credit-unfriendly, because it enables cycling through acquisitions or subsidiary-designation changes to refresh basket capacity. Answer false if basket capacity stays consumed even after the target joins the Restricted Group (credit-friendly default).";
# TODO-ENG: add inv_provision.joinder_releases_basket boolean

insert $inv_k3 isa ontology_question,
    has question_id "inv_k3",
    has covenant_type "INV",
    has question_text "Are Investments in Unrestricted Subsidiaries re-characterized as Restricted Payments?",
    has answer_type "boolean",
    has display_order 1192,
    has extraction_prompt "Determine whether the investments covenant or the Restricted Payments covenant contains a rule re-characterizing certain Investments in Unrestricted Subsidiaries as Restricted Payments — triggering the tighter RP covenant limits (and builder-basket tracking) rather than the Investments covenant. Look for language such as 'Investments in any Unrestricted Subsidiary shall be deemed Restricted Payments for purposes of the Restricted Payments covenant' or a cross-reference linking the two covenants. Answer true if such a re-characterization applies (credit-friendly — funnels unsub investments through the tighter RP framework). Answer false if Investments-in-Unsubs are governed solely by the investments covenant, which is the more common (and more borrower-friendly) structure.";
# TODO-ENG: add inv_provision.unsub_investment_is_rp boolean

insert $inv_k4 isa ontology_question,
    has question_id "inv_k4",
    has covenant_type "INV",
    has question_text "Is there separate compliance-certificate tracking for Material Property contributed to Unsubs?",
    has answer_type "boolean",
    has display_order 1193,
    has extraction_prompt "Determine whether the investments covenant (or the compliance certificate requirement) mandates separate tracking and disclosure of Material Property (IP, revenue-generating assets) contributed to any Unrestricted Subsidiary — a distinct line-item counter from the aggregate Investment basket. Look for language such as 'the Borrower shall track separately on each annual compliance certificate the fair market value of Material Property contributed to Unrestricted Subsidiaries under this clause' or an affirmative reporting obligation tied to unsub-contributions. Answer true if separate tracking is required. Answer false if Material Property contributions are subsumed within the general basket tracking without distinct reporting — a transparency gap.";
# TODO-ENG: add inv_provision.separate_material_property_tracking boolean

insert $inv_k5 isa ontology_question,
    has question_id "inv_k5",
    has covenant_type "INV",
    has question_text "Do Loan Party guarantees of Unrestricted Subsidiary debt consume Investment basket capacity?",
    has answer_type "boolean",
    has display_order 1194,
    has extraction_prompt "Determine whether a guarantee issued by a Loan Party of Indebtedness of an Unrestricted Subsidiary counts against the Investment basket — i.e., basket capacity is reduced by the guaranteed amount. Look in the Investment definition for explicit treatment of such guarantees, or in the investments covenant for a tracking rule addressing Loan-Party guarantees of non-Loan-Party debt. Answer true if such guarantees consume Investment basket capacity — credit-friendly, because it prevents off-balance-sheet credit support from bypassing the investments cap. Answer false if guarantees are excluded from the Investment definition's scope (creating a structural gap where Loan-Party credit can back unsub debt without basket consumption).";
# TODO-ENG: add inv_provision.unsub_guarantee_consumes_basket boolean



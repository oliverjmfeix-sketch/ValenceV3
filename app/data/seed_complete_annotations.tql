################################################################################
# COMPLETE ATTRIBUTE ANNOTATIONS (Phase 2b)
#
# Adds question_annotates_attribute relations for every RP entity attribute
# and entity header that has an existing ontology question.
#
# Does NOT duplicate the 31 annotations in seed_attribute_annotations.tql.
# Does NOT create new questions (that is Phase 2c).
################################################################################

# ═══════════════════════════════════════════════════════════════════════════════
# ENTITY-LEVEL _exists ANNOTATIONS
#
# These annotate entity headers, not individual attributes.
# At display time, the annotation appears after the entity type name
# to explain what the entity's presence means.
# ═══════════════════════════════════════════════════════════════════════════════

# ── Core provisions and baskets ───────────────────────────────────────────────

match $q isa ontology_question, has question_id "rp_a1";
insert (question: $q) isa question_annotates_attribute,
    has target_entity_type "rp_provision",
    has target_attribute_name "_exists";

match $q isa ontology_question, has question_id "rp_c1";
insert (question: $q) isa question_annotates_attribute,
    has target_entity_type "management_equity_basket",
    has target_attribute_name "_exists";

match $q isa ontology_question, has question_id "rp_d1";
insert (question: $q) isa question_annotates_attribute,
    has target_entity_type "tax_distribution_basket",
    has target_attribute_name "_exists";

match $q isa ontology_question, has question_id "rp_f1";
insert (question: $q) isa question_annotates_attribute,
    has target_entity_type "builder_basket",
    has target_attribute_name "_exists";

match $q isa ontology_question, has question_id "rp_g1";
insert (question: $q) isa question_annotates_attribute,
    has target_entity_type "ratio_basket",
    has target_attribute_name "_exists";

match $q isa ontology_question, has question_id "rp_j1";
insert (question: $q) isa question_annotates_attribute,
    has target_entity_type "unsub_designation",
    has target_attribute_name "_exists";

match $q isa ontology_question, has question_id "rp_k1";
insert (question: $q) isa question_annotates_attribute,
    has target_entity_type "jcrew_blocker",
    has target_attribute_name "_exists";

match $q isa ontology_question, has question_id "rp_m1";
insert (question: $q) isa question_annotates_attribute,
    has target_entity_type "unsub_distribution_basket",
    has target_attribute_name "_exists";

match $q isa ontology_question, has question_id "rp_i7";
insert (question: $q) isa question_annotates_attribute,
    has target_entity_type "basket_reallocation",
    has target_attribute_name "_exists";

match $q isa ontology_question, has question_id "rp_l1";
insert (question: $q) isa question_annotates_attribute,
    has target_entity_type "asset_proceeds_source",
    has target_attribute_name "_exists";

match $q isa ontology_question, has question_id "rp_l2";
insert (question: $q) isa question_annotates_attribute,
    has target_entity_type "sweep_tier",
    has target_attribute_name "_exists";

# ── Builder basket sources ────────────────────────────────────────────────────

match $q isa ontology_question, has question_id "rp_f10";
insert (question: $q) isa question_annotates_attribute,
    has target_entity_type "ecf_source",

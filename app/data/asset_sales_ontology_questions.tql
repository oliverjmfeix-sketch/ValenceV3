# ═══════════════════════════════════════════════════════════════════════════════
#
# NOTE: Parts of the asset-sale entity model already exist. The schema
# already has `asset_sale_sweep`, `sweep_tier`, and the `rp_el_sweep_tiers`
# question (in seed_entity_list_questions.tql). Those were built for the RP
# module's cross-covenant needs.
#
# What's missing for a complete Asset Sales entity model:
#
#   entity disposition_basket @abstract,
#     owns basket_id @key,
#     owns basket_cap_usd,
#     owns basket_cap_pct_ebitda,
#     owns ratio_threshold,
#     owns uses_no_worse_than_test,
#     owns sweep_exempt,                  # boolean — does this basket escape the sweep?
#     plays provision_has_disposition_basket:basket;
#
#   entity general_disposition_basket sub disposition_basket;
#   entity ratio_disposition_basket sub disposition_basket;
#   entity intercompany_disposition_basket sub disposition_basket;
#   entity non_collateral_disposition_basket sub disposition_basket;
#   entity ordinary_course_disposition_basket sub disposition_basket;
#   entity license_out_basket sub disposition_basket;
#   entity sale_leaseback_basket sub disposition_basket;
#
# Once added, convert the per-basket _exists questions above (as_b1, as_b4,
# as_c1, as_d1, as_d2, as_d3, as_h1 etc.) into a single entity_list question
# using `answer_type "entity_list"`, `target_entity_type "disposition_basket"`.

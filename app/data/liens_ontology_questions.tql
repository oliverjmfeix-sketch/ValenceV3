#
# The following would extract each permitted lien basket as a typed entity,
# enabling per-basket capacity reporting and cross-covenant correlation
# analysis. Engineering must add the entity types before these can be wired.
#
# Proposed schema additions (for `schema_unified.tql`):
#
#   entity lien_basket @abstract,
#     owns basket_id @key,
#     owns display_name,
#     owns section_reference,
#     owns source_page,
#     owns source_text,
#     owns confidence,
#     owns basket_cap_usd,
#     owns basket_cap_pct_ebitda,
#     owns uses_greater_of,
#     owns has_grower,
#     owns ties_to_debt_basket,          # boolean — is lien tied to a DI basket?
#     owns tied_debt_basket_id,          # string — which DI basket it references
#     owns lien_priority_level,          # first-lien / pari passu / junior / unsecured
#     owns capacity_shared_with_di,      # boolean — shared pool with DI?
#     plays provision_has_lien_basket:basket;
#
#   # Subtypes mirroring the DI basket subtypes:
#   entity general_lien_basket sub lien_basket;
#   entity ratio_lien_basket sub lien_basket, owns ratio_threshold;
#   entity purchase_money_lien_basket sub lien_basket;
#   entity capital_lease_lien_basket sub lien_basket;
#   entity acquisition_lien_basket sub lien_basket;
#   entity refinancing_lien_basket sub lien_basket;
#   entity intercompany_lien_basket sub lien_basket;
#   entity foreign_sub_lien_basket sub lien_basket;
#   entity non_guarantor_lien_basket sub lien_basket;
#   entity existing_lien_basket sub lien_basket;
#
#   relation provision_has_lien_basket sub provision_has_extracted_entity,
#     relates provision,
#     relates basket as extracted;
#
# Once the above is in schema_unified.tql, uncomment the entity_list question
# below and run init_schema.py. The validator will then pass on this file with
# both scalar AND entity_list coverage.
#
# insert $ln_el_baskets isa ontology_question,
#     has question_id "ln_el_baskets",
#     has covenant_type "LIENS",
#     has question_text "Extract all permitted lien baskets.",
#     has answer_type "entity_list",
#     has display_order 1090,
#     has target_entity_type "lien_basket",
#     has target_relation_type "provision_has_lien_basket",
#     has extraction_prompt "Extract ALL permitted lien baskets from the liens covenant. For EACH basket create a separate entity with the most specific subtype applicable (general_lien_basket, ratio_lien_basket, purchase_money_lien_basket, capital_lease_lien_basket, acquisition_lien_basket, refinancing_lien_basket, intercompany_lien_basket, foreign_sub_lien_basket, non_guarantor_lien_basket, existing_lien_basket). Populate: basket_cap_usd (fixed-dollar component or null if unlimited/uncapped), basket_cap_pct_ebitda (grower percentage or null), ties_to_debt_basket (true if the lien basket references a specific debt incurrence basket), tied_debt_basket_id (the debt basket name, e.g. 'general_debt_basket'), lien_priority_level (one of: 'first_lien_priming', 'pari_passu', 'junior', 'unsecured'), and capacity_shared_with_di (true if capacity is shared with the matching DI basket). Include section_reference and source_text for provenance.";

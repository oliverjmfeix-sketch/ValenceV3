# ═══════════════════════════════════════════════════════════════════════════════
# TODO-ENG (extension from audit): additional entity-list candidates
# ═══════════════════════════════════════════════════════════════════════════════
#
# Two additional entity-list candidates surfaced during the Phase 1 audit for
# the 53-question expansion. Both are genuine N-item repeating structures and
# better modeled as typed entities than as parallel scalars.
#
# ───────────────────────────────────────────────────────────────────────────────
# Candidate 2: intercreditor_agreement entity
# ───────────────────────────────────────────────────────────────────────────────
#
# Each credit agreement typically references 2-5 distinct intercreditor
# agreements (first-lien PPIA, junior-lien JLIA, ABL intercreditor, receivables
# intercreditor, etc.). Scalar questions in LN9 capture whether a PPIA / JLIA
# is required in general, but an entity per named ICA gives per-agreement
# shape (applies-to priority, who-may-approve, amendment-threshold).
#
# Proposed schema additions:
#
#   entity intercreditor_agreement,
#     owns agreement_id @key,
#     owns display_name,
#     owns agreement_type,              # "ppia" | "jlia" | "abl_ica" | "receivables_ica"
#     owns applies_to_priority,         # "first_lien" | "pari_passu" | "junior" | "abl"
#     owns requires_lender_vote_to_amend,
#     owns admin_agent_may_approve,
#     owns subthreshold_carveout_usd,   # null if no carve-out, else the $ threshold
#     owns section_reference,
#     owns source_page,
#     owns source_text,
#     owns confidence,
#     plays provision_has_ica:ica;
#
#   relation provision_has_ica sub provision_has_extracted_entity,
#     relates provision,
#     relates ica as extracted;
#
# Deferred entity-list question (uncomment once schema is in):
#
# insert $ln_el_icas isa ontology_question,
#     has question_id "ln_el_icas",
#     has covenant_type "LIENS",
#     has question_text "Extract all intercreditor agreements referenced by the liens covenant.",
#     has answer_type "entity_list",
#     has display_order 1077,
#     has target_entity_type "intercreditor_agreement",
#     has target_relation_type "provision_has_ica",
#     has extraction_prompt "Extract every distinct intercreditor agreement referenced (by name or by defined term) in the liens covenant and its cross-references. For each ICA create an entity: agreement_type (one of 'ppia', 'jlia', 'abl_ica', 'receivables_ica'), applies_to_priority (which lien-priority tier the ICA governs), requires_lender_vote_to_amend (true if ICA amendments require lender consent beyond the Administrative Agent's sole approval), admin_agent_may_approve (true if the Administrative Agent has unilateral authority to enter into or approve the ICA form), subthreshold_carveout_usd (dollar threshold below which the ICA is not required — null if no such carve-out). Include section_reference and source_text for provenance.";
#
# match $cat isa ontology_category, has category_id "LN9";
#       $q isa ontology_question, has question_id "ln_el_icas";
# insert (category: $cat, question: $q) isa category_has_question;
#
# ───────────────────────────────────────────────────────────────────────────────
# Candidate 3: lien_ratio_tier entity
# ───────────────────────────────────────────────────────────────────────────────
#
# Analog to DI's `leverage_tier`. Some agreements tier permitted-lien capacity
# by leverage level — e.g., at <3.00x, unlimited first-lien priming; between
# 3.00x and 4.50x, $X cap; above 4.50x, no new priming liens. Rare in current
# drafting practice but present in stepped-structure deals. Flagged for
# engineering; NO deferred question drafted (wait for real-world frequency
# evidence before wiring).
#
# Proposed schema additions:
#
#   entity lien_ratio_tier,
#     owns tier_id @key,
#     owns tier_number,                 # 1 = most permissive (lowest leverage)
#     owns leverage_floor,              # lower bound (null for tier 1)
#     owns leverage_ceiling,            # upper bound (null = unlimited if is_unlimited)
#     owns permitted_priority,          # "first_lien" | "pari_passu" | "junior"
#     owns capacity_usd,                # fixed dollar cap at this tier, null if unlimited
#     owns is_unlimited,                # true if no cap at this tier
#     owns section_reference,
#     owns source_page,
#     owns source_text,
#     owns confidence,
#     plays provision_has_lien_tier:tier;
#
#   relation provision_has_lien_tier sub provision_has_extracted_entity,
#     relates provision,
#     relates tier as extracted;
#
# No deferred question drafted for this candidate. Revisit after Phase 2 eval
# against real agreements to confirm prevalence of tiered lien-priming structures.

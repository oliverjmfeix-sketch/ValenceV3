#     has question_id "xyz_el_baskets",
#     has covenant_type "XYZ",
#     has question_text "Extract all permitted <module> baskets.",
#     has answer_type "entity_list",
#     has display_order 1090,
#     has target_entity_type "xyz_basket",
#     has target_relation_type "provision_has_xyz_basket",
#     has extraction_prompt "Extract ALL permitted <module> baskets listed in the covenant. For EACH basket include: basket_cap_usd (the fixed dollar component), basket_cap_pct_ebitda (the grower percentage if any), requires_no_default (boolean), section_reference, and source_text. Do not merge distinct baskets into one entity — even if they share a common cap, extract separately.";


# ═══════════════════════════════════════════════════════════════════════════════
# CATEGORY → QUESTION LINKAGE
# ═══════════════════════════════════════════════════════════════════════════════
#
# Each question MUST be linked to exactly one category via category_has_question.
# Categories without questions and questions without categories are caught by the
# validator.
#
# Pattern: one two-line block per link, with `match` selecting the category and
# question, and `insert` adding the relation.

match $cat isa ontology_category, has category_id "XYZ1";
      $q isa ontology_question, has question_id "xyz_a1";
insert (category: $cat, question: $q) isa category_has_question;

match $cat isa ontology_category, has category_id "XYZ1";
      $q isa ontology_question, has question_id "xyz_a2";
insert (category: $cat, question: $q) isa category_has_question;

match $cat isa ontology_category, has category_id "XYZ1";
      $q isa ontology_question, has question_id "xyz_a3";
insert (category: $cat, question: $q) isa category_has_question;

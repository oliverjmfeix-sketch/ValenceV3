# ═══════════════════════════════════════════════════════════════════════════════
# EXTENDED ONTOLOGY QUESTIONS
#
# Additional RP entity questions beyond the core set in questions.tql.
# Each question has: ontology_question entity, question_targets_field mapping,
# and category_has_question linkage.
#
# Annotations are in question_annotations.tql (separate file).
# ═══════════════════════════════════════════════════════════════════════════════
insert $q_g8 isa ontology_question,
    has question_id "rp_g8",
    has question_text "What ratio type is used for the unlimited dividend basket?",
    has description "First lien, total, secured, or net leverage ratio",
    has answer_type "string",
    has ui_display_type "text_input",
    has is_required false,
    has display_order 68,
    has covenant_type "RP";
(question: $q_g8) isa question_targets_field,
    has target_field_name "ratio_basket_type",
    has target_entity_type "rp_provision";

insert $q_g9 isa ontology_question,
    has question_id "rp_g9",
    has question_text "Is the ratio tested on a pro forma basis?",
    has description "Whether leverage is measured after giving effect to the dividend",
    has answer_type "boolean",
    has ui_display_type "checkbox",
    has is_required false,
    has display_order 69,
    has covenant_type "RP";
(question: $q_g9) isa question_targets_field,
    has target_field_name "ratio_pro_forma_basis",
    has target_entity_type "rp_provision";

insert $q_g10 isa ontology_question,
    has question_id "rp_g10",
    has question_text "When is the ratio tested?",
    has description "Declaration date, payment date, or most recent fiscal quarter",
    has answer_type "string",
    has ui_display_type "text_input",
    has is_required false,
    has display_order 70,
    has covenant_type "RP";
(question: $q_g10) isa question_targets_field,
    has target_field_name "ratio_test_date_type",
    has target_entity_type "rp_provision";

insert $q_g11 isa ontology_question,
    has question_id "rp_g11",
    has question_text "Is Limited Condition Transaction treatment available for the ratio basket?",
    has description "Whether LCT election freezes the test date for ratio compliance",
    has answer_type "boolean",
    has ui_display_type "checkbox",
    has is_required false,
    has display_order 71,
    has covenant_type "RP";
(question: $q_g11) isa question_targets_field,
    has target_field_name "ratio_lct_treatment_available",
    has target_entity_type "rp_provision";

insert $q_g12 isa ontology_question,
    has question_id "rp_g12",
    has question_text "What is the no-worse leverage threshold?",
    has description "Maximum ratio permitted under the no-worse test if different from unlimited threshold",
    has answer_type "number",
    has ui_display_type "number_input",
    has is_required false,
    has display_order 72,
    has covenant_type "RP";
(question: $q_g12) isa question_targets_field,
    has target_field_name "ratio_no_worse_threshold",
    has target_entity_type "rp_provision";


# ── Unsub distribution basket (Section 6.06(p) carve-out) ────────────────────
attribute covers_equity_interests, value boolean;
attribute covers_indebtedness, value boolean;
attribute covers_assets, value boolean;
attribute covers_proceeds, value boolean;
attribute is_categorical, value boolean;

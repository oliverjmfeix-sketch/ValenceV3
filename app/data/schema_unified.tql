# ── Basket reallocation (on basket_reallocates_to relation) ──────────────────
attribute reallocation_source, value string;       # canonical: investment_basket | rdp_basket |
                                                    #   prepayment_basket | builder_basket | general_rp_basket
attribute reallocation_amount_usd, value double;
attribute is_bidirectional, value boolean;
attribute reduces_source_basket, value boolean;
attribute reduction_is_dollar_for_dollar, value boolean;
attribute reduction_while_outstanding_only, value boolean;
attribute reallocation_grower_pct, value double;

# ── Cross-covenant mapping ────────────────────────────────────────────────────
attribute basket_type_name, value string;
attribute provision_type_name, value string;
attribute mapping_id, value string;
attribute capacity_category, value string;
attribute capacity_effect, value string;

# ── Investment pathway (J.Crew chain analysis) ────────────────────────────────
attribute pathway_source_type, value string;       # loan_party | restricted_sub | non_guarantor_rs
attribute pathway_target_type, value string;       # unrestricted_sub | non_guarantor_rs
attribute cap_dollar_usd, value double;
attribute cap_pct_total_assets, value double;
attribute is_uncapped, value boolean;
attribute can_stack_with_other_baskets, value boolean;

# ── RDP baskets (Section 6.09 — Restricted Debt Payments) ────────────────────
attribute requires_same_or_lower_priority, value boolean;
attribute requires_same_or_later_maturity, value boolean;
attribute requires_no_increase_in_principal, value boolean;
attribute permits_refinancing_with_equity, value boolean;
attribute subject_to_intercreditor, value boolean;
attribute shares_with_rp_builder, value boolean;   # whether RDP draws from same Available Amount as RP
attribute uses_closing_ratio_alternative, value boolean;  # T12 Q326-327: ratio = greater of fixed and closing
attribute requires_qualified_stock_only, value boolean;
attribute requires_cash_common_equity, value boolean;

# ── MFN Channel 3 entity attributes (owned by yield_def / sunset) ────────────
attribute oid_amortization_method, value string;
attribute oid_amortization_years, value integer;
attribute sunset_exists, value boolean;
attribute sunset_period_months, value integer;
attribute sunset_tied_to_maturity, value boolean;
attribute sunset_resets_on_refi, value boolean;
attribute sunset_timing_loophole, value boolean;

# ── New boolean attributes for Channel 2 elimination ─────────────────────────

# Covenant scope (on rp_provision)
attribute restricts_borrower, value boolean;
attribute restricts_guarantors, value boolean;
attribute restricts_restricted_subs, value boolean;
attribute restricts_holdings, value boolean;

# RP definition scope (on rp_provision)
attribute includes_cash_dividends, value boolean;
attribute includes_share_buybacks, value boolean;
attribute includes_distributions, value boolean;
attribute includes_debt_prepayments, value boolean;
attribute includes_investments, value boolean;
attribute includes_guarantees, value boolean;

# RDP definition scope (on rp_provision)
attribute rdp_includes_voluntary_payments, value boolean;
attribute rdp_includes_optional_payments, value boolean;
attribute rdp_includes_prepayments, value boolean;
attribute rdp_includes_redemptions, value boolean;
attribute rdp_includes_defeasance, value boolean;
attribute rdp_includes_open_market_purchases, value boolean;

# Management equity — covered persons (on management_equity_basket)
attribute covers_employees, value boolean;
attribute covers_officers, value boolean;
attribute covers_directors, value boolean;
attribute covers_consultants, value boolean;
attribute covers_estates, value boolean;
attribute covers_sponsor_employees, value boolean;

# Management equity — triggers (on management_equity_basket)
attribute trigger_death, value boolean;
attribute trigger_disability, value boolean;
attribute trigger_termination, value boolean;
attribute trigger_retirement, value boolean;
attribute trigger_change_of_control, value boolean;

# Tax distribution — group types (on tax_distribution_basket)
attribute covers_consolidated_group, value boolean;
attribute covers_combined_group, value boolean;
attribute covers_similar_groups, value boolean;
attribute covers_disregarded_entities, value boolean;

# Equity award — additional types (on equity_award_basket)
attribute covers_net_settlement, value boolean;
attribute covers_clawback, value boolean;
attribute covers_forfeiture, value boolean;

# Holdco overhead — additional costs (on holdco_overhead_basket)
attribute covers_insurance_premiums, value boolean;
attribute covers_director_fees, value boolean;
attribute covers_audit_fees, value boolean;
attribute covers_legal_fees, value boolean;

# J.Crew blocker — IP type coverage booleans (on jcrew_blocker)
attribute covers_patents, value boolean;
attribute covers_trademarks, value boolean;
attribute covers_copyrights, value boolean;
attribute covers_trade_secrets, value boolean;
attribute covers_software, value boolean;
attribute covers_domain_names, value boolean;
attribute covers_know_how, value boolean;
attribute covers_customer_data, value boolean;
attribute covers_licenses_granted, value boolean;
attribute covers_licenses_received, value boolean;

# J.Crew blocker — additional transfer types (on jcrew_blocker)
attribute covers_assignment, value boolean;
attribute covers_sale, value boolean;
attribute covers_contribution_to_capital, value boolean;
attribute covers_non_renewal, value boolean;

# J.Crew blocker — additional binding/timing (on jcrew_blocker)
attribute binds_holdings, value boolean;
attribute binds_borrower_only, value boolean;
attribute covers_post_designation, value boolean;

# Builder basket — reduction tracking (on builder_basket)
attribute reduced_by_rp_usage, value boolean;
attribute reduced_by_rdp_usage, value boolean;
attribute reduced_by_investment_usage, value boolean;
attribute reduced_by_designation, value boolean;

# Unsub distribution basket — mechanics (on unsub_distribution_basket)
attribute rebuilds_builder_basket, value boolean;
attribute includes_noncash_at_fmv, value boolean;
attribute reduces_investment_basket, value boolean;
attribute rebuild_is_capped, value boolean;
attribute rebuild_cap_formula, value string;
attribute redesignation_returns_investment, value boolean;
attribute redesignation_valuation_method, value string;
attribute distributions_can_cascade, value boolean;
attribute has_anti_duplication, value boolean;

# Ratio basket — gap closure (on ratio_basket)
attribute interest_coverage_threshold, value double;
attribute has_multiple_tiers, value boolean;

# Sweep — gap closure
attribute ratio_basket_avoids_sweep, value boolean;
attribute sweep_exempt_ratio_threshold, value double;

# Investment pathway — rebuild (on investment_pathway)
attribute basket_can_rebuild, value boolean;

# Abstract rp_basket — cross-cutting condition
attribute requires_ratio_test, value boolean;

# ── New attributes for cross-document entity types ───────────────────────────

# Intercompany dividend permission
attribute permission_id, value string;
attribute permits_to_borrower, value boolean;
attribute permits_to_guarantors, value boolean;
attribute permits_to_holdings, value boolean;
attribute permits_to_non_guarantor_subs, value boolean;

# Definition analysis
attribute definition_id, value string;
attribute has_standalone_definition, value boolean;
attribute definition_source, value string;
attribute verbatim_text, value string;

# IP definition
attribute excludes_trade_secrets, value boolean;
attribute excludes_know_how, value boolean;
attribute excludes_software, value boolean;
attribute excludes_inbound_licenses, value boolean;
attribute excludes_customer_data, value boolean;

# Transfer definition
attribute excludes_exclusive_licensing, value boolean;
attribute excludes_any_licensing, value boolean;
attribute excludes_pledge, value boolean;
attribute excludes_abandonment, value boolean;

# Materiality definition
attribute is_subjective, value boolean;
attribute has_dollar_threshold, value boolean;
attribute has_percentage_threshold, value boolean;
attribute determined_by_board, value boolean;
attribute enumerated_on_schedule, value boolean;
attribute defined_negatively, value boolean;
attribute can_be_manipulated, value boolean;

# Lien release mechanics
attribute release_id, value string;
attribute auto_release_on_transfer, value boolean;
attribute requires_agent_consent, value boolean;
attribute requires_lender_consent, value boolean;
attribute requires_all_lender_consent_for_ip, value boolean;

# Amendment threshold
attribute amendment_id, value string;
attribute provision_type, value string;
attribute requires_all_lender_consent, value boolean;
attribute requires_supermajority, value boolean;
attribute supermajority_threshold, value double;
attribute required_lenders_sufficient, value boolean;

# Concept metadata (on abstract concept entity)
attribute target_entity_attribute, value string;


################################################################################
# §2  CORE ENTITIES
#
#   Provision types are ANCHORS with two classes of owned attributes:
#
#   1. PROVISION-SCOPE SCALARS — facts about the provision itself that have
#      no entity counterpart. Populated by annotation routing from ontology
#      questions (question_annotates_attribute → _set_entity_attribute).
#      Examples: restricts_borrower, threshold_bps, sacred_right_status.
#
#   2. PATTERN FLAGS — scalar answers from extraction (e.g., rp_z1..z3,
#      mfn_40..42), also annotation-routed. Not computed by TypeDB functions.
#
#   Structured data (baskets, exclusions, yield definitions, etc.) goes
#   through typed entities via provision_has_extracted_entity sub-relations.
#   Scalar answers also stored in provision_has_answer for the comparison grid.
#
#   Provision attributes are surfaced in the PROVISION header block during
#   synthesis via the $p.* wildcard fetch in get_provision_entities().
################################################################################

entity deal,
    owns deal_id @key,
    owns deal_name,
    owns borrower_name,
    owns deal_date,
    owns deal_amount,
    owns deal_currency,
    owns deal_type,
    owns facility_type,
    owns created_at,
    owns updated_at,
    plays deal_has_provision:deal,
    plays deal_has_document:deal,
    plays comparison_includes_deal:deal;

entity document,
    owns document_url @key,
    owns document_hash,
    owns page_count,
    owns created_at,
    plays deal_has_document:document;

entity provision @abstract,
    owns provision_id @key,
    owns section_reference,
    owns source_page,
    owns extracted_at,
    owns condition_logic,
    plays deal_has_provision:provision,
    plays provision_has_answer:provision,
    plays concept_applicability:provision,
    plays has_provenance:attributed_entity,
    plays provision_cross_reference:source_provision,
    plays provision_cross_reference:target_provision,
    plays answer_has_qualification:qualified_answer,
    plays answer_has_citation:cited_answer;

entity mfn_provision sub provision,
    # Annotation-routed pattern flags (via seed_mfn_annotations.tql)
    owns yield_exclusion_pattern_detected,
    owns reclassification_loophole_detected,
    owns bridge_to_term_loophole_detected,
    # MFN1: Core Structure scalars
    owns mfn_exists,
    owns threshold_bps,
    owns margin_only_threshold,
    owns automatic_adjustment,
    owns adjustment_scope,
    owns bilateral_protection,
    # MFN5: Governance scalars
    owns amendment_consent_threshold,
    owns sacred_right_status,
    owns transaction_specific_waiver,
    owns agent_discretion,
    owns affected_lender_optout,
    # Relations
    plays provision_has_exclusion:provision,
    plays provision_has_yield_def:provision,
    plays provision_has_sunset:provision,
    plays provision_has_freebie:provision,
    plays has_amendment_threshold:entity_with_threshold,
    plays di_provision_links_mfn:mfn_prov,
    plays incremental_triggers_mfn:mfn_prov;

entity rp_provision sub provision,
    owns jcrew_pattern_detected,
    owns serta_pattern_detected,
    owns collateral_leakage_pattern_detected,
    owns restricts_borrower,
    owns restricts_guarantors,
    owns restricts_restricted_subs,
    owns restricts_holdings,
    owns includes_cash_dividends,
    owns includes_share_buybacks,
    owns includes_distributions,
    owns includes_debt_prepayments,
    owns includes_investments,
    owns includes_guarantees,
    owns rdp_includes_voluntary_payments,
    owns rdp_includes_optional_payments,
    owns rdp_includes_prepayments,
    owns rdp_includes_redemptions,
    owns rdp_includes_defeasance,
    owns rdp_includes_open_market_purchases,
    plays provision_has_basket:provision,
    plays provision_has_rdp_basket:provision,
    plays provision_has_blocker:provision,
    plays provision_has_unsub:provision,
    plays provision_has_sweep_tier:provision,
    plays provision_has_asset_sale_sweep:provision,
    plays provision_has_pathway:provision,
    plays provision_has_intercompany_permission:provision,
    plays provision_has_definition:provision,
    plays provision_has_lien_release:provision,
    plays has_amendment_threshold:entity_with_threshold,
    plays di_provision_links_rp:rp_prov;


################################################################################
# §3  EXTRACTED ENTITIES
#
#   Created by answer_type = "entity" questions.
#   The pipeline introspects each entity's owned attributes at runtime:
#
#     match entity $et type <name>; $et owns $attr; select $attr;
#
#   to auto-generate Claude's JSON response schema.
#
#   Adding `owns new_attribute` here is the ONLY change needed to
#   capture a new field. Prompt, storage, and API adapt automatically.
################################################################################

# ═══════════════════════════════════════════════════════════════════════════════
# BASKETS
#
#   Abstract parent with shared provenance. Each subtype is a distinct basket
#   that lawyers analyze as a self-contained provision unit.
# ═══════════════════════════════════════════════════════════════════════════════

entity rp_basket @abstract,
    owns basket_id @key,
    owns display_name,
    owns section_reference,
    owns source_page,
    owns source_text,
    owns confidence,
    owns default_condition,
    owns requires_ratio_test,
    owns capacity_category,
    plays provision_has_basket:basket,
    plays basket_reallocates_to:source_basket,
    plays basket_reallocates_to:target_basket,
    plays shares_capacity_pool:pool_member;

entity builder_basket sub rp_basket,
    owns basket_amount_usd,
    owns start_date_language,
    owns uses_greatest_of_tests,
    owns reduced_by_rp_usage,
    owns reduced_by_rdp_usage,
    owns reduced_by_investment_usage,
    owns reduced_by_designation,
    # Source existence flags (flattened from builder_basket_source subtypes)
    owns has_starter_amount_source,
    owns has_cni_source,
    owns has_ecf_source,
    owns has_ebitda_fc_source,
    owns has_equity_proceeds_source,
    owns has_asset_proceeds_source,
    owns has_investment_returns_source,
    owns has_debt_conversion_source,
    # Starter amount details
    owns starter_dollar_amount,
    owns starter_ebitda_pct,
    owns starter_uses_greater_of,
    # CNI details
    owns cni_percentage,
    owns cni_is_primary_test,
    # ECF details
    owns ecf_retained_formula,
    owns ecf_lookback_quarters,
    # EBITDA-FC details
    owns ebitda_fc_multiplier,
    # Equity proceeds details
    owns equity_proceeds_pct,
    owns equity_excludes_cure,
    owns equity_excludes_disqualified,
    # Asset proceeds details
    owns asset_proceeds_pct,
    owns asset_proceeds_sweep_section,
    owns asset_proceeds_ratio_disposition,
    owns asset_proceeds_ratio_threshold,
    plays di_feeds_rp_builder:builder;

entity ratio_basket sub rp_basket,
    owns ratio_threshold,
    owns ratio_type,
    owns is_unlimited_if_met,
    owns has_no_worse_test,
    owns no_worse_threshold,
    owns no_worse_is_uncapped,
    owns test_date_type,
    owns lct_treatment_available,
    owns pro_forma_basis,
    owns interest_coverage_threshold,
    owns has_multiple_tiers;

entity general_rp_basket sub rp_basket,
    owns basket_amount_usd,
    owns basket_grower_pct,
    owns is_per_annum;

entity management_equity_basket sub rp_basket,
    owns annual_cap_usd,
    owns annual_cap_pct_ebitda,
    owns cap_uses_greater_of,
    owns carryforward_permitted,
    owns carryforward_max_years,
    owns eligible_person_scope,
    owns covers_employees,
    owns covers_officers,
    owns covers_directors,
    owns covers_consultants,
    owns covers_estates,
    owns covers_sponsor_employees,
    owns trigger_death,
    owns trigger_disability,
    owns trigger_termination,
    owns trigger_retirement,
    owns trigger_change_of_control;

entity tax_distribution_basket sub rp_basket,
    owns standalone_taxpayer_limit,
    owns hypothetical_tax_rate,
    owns tax_sharing_permitted,
    owns estimated_taxes_permitted,
    owns covers_consolidated_group,
    owns covers_combined_group,
    owns covers_similar_groups,
    owns covers_disregarded_entities;

entity holdco_overhead_basket sub rp_basket,
    owns annual_cap_usd,
    owns covers_management_fees,
    owns covers_admin_expenses,
    owns covers_franchise_taxes,
    owns management_fee_recipient_scope,
    owns requires_arms_length,
    owns requires_board_approval,
    owns covers_insurance_premiums,
    owns covers_director_fees,
    owns covers_audit_fees,
    owns covers_legal_fees;

entity equity_award_basket sub rp_basket,
    owns annual_cap_usd,
    owns covers_cashless_exercise,
    owns covers_tax_withholding,
    owns carryforward_permitted,
    owns covers_net_settlement,
    owns covers_clawback,
    owns covers_forfeiture;

entity unsub_distribution_basket sub rp_basket,
    owns covers_equity_interests,
    owns covers_indebtedness,
    owns covers_assets,
    owns covers_proceeds,
    owns is_categorical,
    owns requires_valid_designation,
    owns rebuilds_builder_basket,
    owns includes_noncash_at_fmv,
    owns reduces_investment_basket,
    owns rebuild_is_capped,
    owns rebuild_cap_formula,
    owns redesignation_returns_investment,
    owns redesignation_valuation_method,
    owns distributions_can_cascade,
    owns has_anti_duplication;

# Investment basket — real entity under its own provision (Section 6.03).
# Connected to RP provision ONLY via basket_reallocates_to edges, NOT
# via provision_has_basket on the RP provision. This prevents the
# dividend_capacity_components function from double-counting it
# (Branch 1 = direct baskets, Branch 2 = reallocation sources).
entity general_investment_basket sub rp_basket,
    owns basket_amount_usd,
    owns basket_grower_pct;

# Investment provision — lightweight provision for the investment covenant.
# Its baskets are separate from RP baskets but reachable via reallocation.
entity investment_provision sub provision,
    plays provision_has_basket:provision;

# ═══════════════════════════════════════════════════════════════════════════════
# BUILDER BASKET SOURCES (polymorphic)
#
#   Each subtype represents a distinct source feeding the builder basket.
#   Claude uses a source_type discriminator in its JSON to select subtype.
#   The pipeline introspects each subtype's attributes independently.
# ═══════════════════════════════════════════════════════════════════════════════

attribute source_name, value string;

# builder_basket_source hierarchy REMOVED — flattened onto builder_basket entity
# (starter_amount_source, cni_source, ecf_source, ebitda_fc_source,
#  equity_proceeds_source, investment_returns_source, asset_proceeds_source,
#  debt_conversion_source — all now scalar attrs on builder_basket)

# ═══════════════════════════════════════════════════════════════════════════════
# SWEEP TIERS
#
#   Variable-length: real credit agreements have 2-4 tiers.
#   Flat schemas can only represent a fixed number. Entities don't.
# ═══════════════════════════════════════════════════════════════════════════════

entity sweep_tier,
    owns tier_id @key,
    owns leverage_threshold,
    owns sweep_percentage,
    owns is_highest_tier,
    owns ratio_basket_avoids_sweep,
    owns sweep_exempt_ratio_threshold,
    owns section_reference,
    owns source_page,
    owns source_text,
    owns confidence,
    plays provision_has_sweep_tier:tier;

# ═══════════════════════════════════════════════════════════════════════════════
# J.CREW BLOCKER
#
#   The blocker is an entity with scope attributes.
#   Exceptions are polymorphic subtypes — where loopholes hide.
# ═══════════════════════════════════════════════════════════════════════════════

entity jcrew_blocker,
    owns blocker_id @key,
    owns covers_transfer,
    owns covers_designation,
    owns covers_ip,
    owns covers_material_assets,
    owns covers_exclusive_licensing,
    owns covers_nonexclusive_licensing,
    owns covers_pledge,
    owns covers_abandonment,
    owns binds_loan_parties,
    owns binds_restricted_subs,
    owns is_sacred_right,
    owns covers_patents,
    owns covers_trademarks,
    owns covers_copyrights,
    owns covers_trade_secrets,
    owns covers_software,
    owns covers_domain_names,
    owns covers_know_how,
    owns covers_customer_data,
    owns covers_licenses_granted,
    owns covers_licenses_received,
    owns covers_assignment,
    owns covers_sale,
    owns covers_contribution_to_capital,
    owns covers_non_renewal,
    owns binds_holdings,
    owns binds_borrower_only,
    owns covers_post_designation,
    owns section_reference,
    owns source_page,
    owns source_text,
    owns confidence,
    plays provision_has_blocker:blocker,
    plays blocker_has_exception:blocker,
    plays blocker_covers_ip_type:blocker,
    plays has_amendment_threshold:entity_with_threshold;

attribute exception_name, value string;

entity blocker_exception @abstract,
    owns exception_id @key,
    owns exception_name,
    owns scope_limitation,
    owns section_reference,
    owns source_page,
    owns source_text,
    owns confidence,
    plays blocker_has_exception:exception;

entity nonexclusive_license_exception sub blocker_exception;
entity intercompany_exception sub blocker_exception;
entity immaterial_ip_exception sub blocker_exception;
entity fair_value_exception sub blocker_exception;
entity ordinary_course_exception sub blocker_exception;
entity license_back_exception sub blocker_exception;

# ═══════════════════════════════════════════════════════════════════════════════
# UNRESTRICTED SUBSIDIARY DESIGNATION
# ═══════════════════════════════════════════════════════════════════════════════

entity unsub_designation,
    owns designation_id @key,
    owns requires_no_default,
    owns requires_board_approval,
    owns dollar_cap_usd,
    owns pct_cap_assets,
    owns redesignation_permitted,
    owns section_reference,
    owns source_page,
    owns source_text,
    owns confidence,
    plays provision_has_unsub:designation;

# ═══════════════════════════════════════════════════════════════════════════════
# ASSET SALE SWEEP (replaces de_minimis_threshold + sweep_exemption)
#
#   Single-instance per provision. Captures mandatory prepayment mechanics:
#   de minimis thresholds (individual + annual) and exemption flags.
# ═══════════════════════════════════════════════════════════════════════════════

entity asset_sale_sweep,
    owns sweep_id @key,
    owns individual_de_minimis_usd,
    owns individual_de_minimis_pct,
    owns individual_uses_greater_of,
    owns annual_de_minimis_usd,
    owns annual_de_minimis_pct,
    owns annual_uses_greater_of,
    owns annual_permits_carryforward,
    owns exempt_non_collateral,
    owns exempt_ordinary_course,
    owns exempt_casualty,
    owns exempt_below_threshold,
    owns exempt_ratio_basket,
    owns section_reference,
    owns source_page,
    owns source_text,
    owns confidence,
    plays provision_has_asset_sale_sweep:sweep;

# basket_reallocation entity REMOVED — data stored as basket_reallocates_to relation
# (connects source basket to target basket with reallocation attributes)

entity cross_covenant_mapping,
    owns mapping_id @key,
    owns basket_type_name,
    owns provision_type_name;

entity basket_capacity_class,
    owns mapping_id @key,
    owns basket_type_name,
    owns capacity_category;

# ═══════════════════════════════════════════════════════════════════════════════
# INVESTMENT PATHWAYS (J.Crew chain analysis)
#
#   Models how value moves between entity types in the corporate structure.
#   The J.Crew "chain" is LP → Non-Guarantor RS → Unsub.
#   Each link is a pathway with its own cap and conditions.
#   Graph traversal detects open chains that flat booleans cannot:
#
#     match
#       $prov isa rp_provision;
#       ($prov, $p1) isa provision_has_pathway;
#       $p1 has pathway_source_type "loan_party",
#          has pathway_target_type "non_guarantor_rs";
#       ($prov, $p2) isa provision_has_pathway;
#       $p2 has pathway_source_type "non_guarantor_rs",
#          has pathway_target_type "unrestricted_sub",
#          has is_uncapped true;
# ═══════════════════════════════════════════════════════════════════════════════

entity investment_pathway,
    owns pathway_id @key,
    owns pathway_source_type,
    owns pathway_target_type,
    owns cap_dollar_usd,
    owns cap_pct_total_assets,
    owns cap_uses_greater_of,
    owns is_uncapped,
    owns can_stack_with_other_baskets,
    owns basket_can_rebuild,
    owns section_reference,
    owns source_page,
    owns source_text,
    owns confidence,
    plays provision_has_pathway:pathway;

# ═══════════════════════════════════════════════════════════════════════════════
# RDP BASKETS (Section 6.09 — Restricted Debt Payments)
#
#   Parallel to RP baskets but for prepayment/redemption of junior debt.
#   Previously modeled as flat multiselect (rdp_basket_type concept) —
#   that captured WHICH baskets exist but not their CONDITIONS.
#
#   Entity treatment captures the structural detail lawyers actually need:
#   refinancing requires same/lower priority? Same/later maturity?
#   Ratio basket tested pro forma? Uses closing ratio alternative?
# ═══════════════════════════════════════════════════════════════════════════════

entity rdp_basket @abstract,
    owns basket_id @key,
    owns display_name,
    owns section_reference,
    owns source_page,
    owns source_text,
    owns confidence,
    owns default_condition,
    owns capacity_category,
    plays provision_has_rdp_basket:rdp_basket,
    plays basket_reallocates_to:source_basket,
    plays basket_reallocates_to:target_basket;

# T2/T3: Refinancing — prepay junior debt with new debt at same/lower priority
entity refinancing_rdp_basket sub rdp_basket,
    owns requires_same_or_lower_priority,
    owns requires_same_or_later_maturity,
    owns requires_no_increase_in_principal,
    owns permits_refinancing_with_equity,
    owns requires_qualified_stock_only,
    owns not_otherwise_applied,
    owns subject_to_intercreditor;

# T9: Fixed dollar basket — general RDP capacity
entity general_rdp_basket sub rdp_basket,
    owns basket_amount_usd,
    owns basket_grower_pct;

# T12: Ratio-based unlimited — leverage test unlocks unlimited RDP
entity ratio_rdp_basket sub rdp_basket,
    owns ratio_threshold,
    owns ratio_type,
    owns is_unlimited_if_met,
    owns test_date_type,
    owns pro_forma_basis,
    owns uses_closing_ratio_alternative;

# T1: Builder/Cumulative Amount for RDP — shares capacity with RP builder?
entity builder_rdp_basket sub rdp_basket,
    owns shares_with_rp_builder,
    owns subject_to_intercreditor;

# T6: Equity contribution funded — RDP funded by fresh equity
entity equity_funded_rdp_basket sub rdp_basket,
    owns requires_qualified_stock_only,
    owns requires_cash_common_equity,
    owns not_otherwise_applied;

# ═══════════════════════════════════════════════════════════════════════════════
# INTERCOMPANY DIVIDEND PERMISSION
# ═══════════════════════════════════════════════════════════════════════════════

entity intercompany_dividend_permission,
    owns permission_id @key,
    owns permits_to_borrower,
    owns permits_to_guarantors,
    owns permits_to_holdings,
    owns permits_to_non_guarantor_subs,
    owns section_reference,
    owns source_page,
    owns source_text,
    owns confidence,
    plays provision_has_intercompany_permission:permission;

# ═══════════════════════════════════════════════════════════════════════════════
# DEFINITION ANALYSIS (cross-document applicable)
#
#   Quality analysis of defined terms. Subtypes per term type.
#   Applicable across RP, MFN, Investments, Asset Sales.
# ═══════════════════════════════════════════════════════════════════════════════

entity definition_analysis @abstract,
    owns definition_id @key,
    owns defined_term,
    owns has_standalone_definition,
    owns definition_source,
    owns verbatim_text,
    owns section_reference,
    owns source_page,
    owns source_text,
    owns confidence,
    plays provision_has_definition:definition;

entity ip_definition sub definition_analysis,
    owns excludes_trade_secrets,
    owns excludes_know_how,
    owns excludes_software,
    owns excludes_inbound_licenses,
    owns excludes_customer_data;

entity transfer_definition sub definition_analysis,
    owns excludes_exclusive_licensing,
    owns excludes_any_licensing,
    owns excludes_pledge,
    owns excludes_abandonment;

entity materiality_definition sub definition_analysis,
    owns is_subjective,
    owns has_dollar_threshold,
    owns has_percentage_threshold,
    owns determined_by_board,
    owns enumerated_on_schedule,
    owns defined_negatively,
    owns can_be_manipulated,
    owns uses_greater_of;

# ═══════════════════════════════════════════════════════════════════════════════
# LIEN RELEASE MECHANICS (cross-document applicable)
# ═══════════════════════════════════════════════════════════════════════════════

entity lien_release_mechanics,
    owns release_id @key,
    owns auto_release_on_transfer,
    owns requires_agent_consent,
    owns requires_lender_consent,
    owns requires_all_lender_consent_for_ip,
    owns section_reference,
    owns source_page,
    owns source_text,
    owns confidence,
    plays provision_has_lien_release:lien_release;

# ═══════════════════════════════════════════════════════════════════════════════
# AMENDMENT THRESHOLD (cross-document applicable)
# ═══════════════════════════════════════════════════════════════════════════════

entity amendment_threshold,
    owns amendment_id @key,
    owns provision_type,
    owns requires_all_lender_consent,
    owns requires_supermajority,
    owns supermajority_threshold,
    owns required_lenders_sufficient,
    owns required_lenders_pct,
    owns has_sacred_rights,
    owns section_reference,
    owns source_page,
    owns source_text,
    owns confidence,
    plays has_amendment_threshold:threshold;


# ═══════════════════════════════════════════════════════════════════════════════
# MFN ENTITIES (Channel 3)
#
#   Structured data for MFN analysis. Each entity captures a complete
#   legal provision unit — exclusion type, yield methodology, sunset,
#   or freebie basket — with full provenance.
#
#   Matches the RP entity pattern: introspect-at-runtime, no hardcoded fields.
# ═══════════════════════════════════════════════════════════════════════════════

# ── New MFN attributes ───────────────────────────────────────────────────────

attribute exclusion_id, value string;
attribute exclusion_type, value string;
attribute exclusion_has_cap, value boolean;
attribute exclusion_cap_usd, value double;
attribute exclusion_cap_pct_ebitda, value double;
attribute exclusion_conditions, value string;
attribute can_stack_with_other_exclusions, value boolean;
attribute excludes_from_mfn, value boolean;
attribute exclusion_scope, value string;
attribute applies_when, value string;
attribute condition_logic, value string;

attribute yield_def_id, value string;
attribute defined_term, value string;
attribute includes_margin, value boolean;
attribute includes_floor_benefit, value boolean;
attribute includes_oid, value boolean;
attribute includes_upfront_fees, value boolean;
attribute includes_commitment_fees, value boolean;
attribute includes_other_fees, value boolean;
attribute comparison_baseline, value string;

attribute sunset_id, value string;
attribute sunset_trigger_event, value string;

attribute freebie_id, value string;
attribute dollar_amount_usd, value double;
attribute ebitda_pct, value double;
attribute stacks_with_general_basket, value boolean;
attribute general_basket_amount_usd, value double;
attribute total_mfn_exempt_capacity_usd, value double;

attribute mfn_universe_field, value string;
attribute di_universe_field, value string;

# ── MFN provision-level scalar attributes ────────────────────────────────────
# Surfaced via question_annotates_attribute → polymorphic fetch annotations.
# MFN1: Core Structure
attribute mfn_exists, value boolean;
attribute threshold_bps, value integer;
attribute margin_only_threshold, value boolean;
attribute automatic_adjustment, value boolean;
attribute adjustment_scope, value string;
attribute bilateral_protection, value boolean;
# MFN3: Yield (on mfn_yield_definition)
attribute differentiates_fixed_floating, value boolean;
attribute yield_determination_authority, value string;
attribute yield_recalculated_at_incurrence, value boolean;
attribute reference_rate_changes_affect_yield, value boolean;
attribute market_price_affects_yield, value boolean;
# MFN5: Governance
attribute amendment_consent_threshold, value string;
attribute sacred_right_status, value boolean;
attribute transaction_specific_waiver, value boolean;
attribute agent_discretion, value boolean;
attribute affected_lender_optout, value boolean;

# ── DI (Debt Incurrence) identifiers ────────────────────────────────────────
attribute ratio_test_type_id, value string;
attribute condition_type_id, value string;
attribute priority_id, value string;
attribute facility_type_id, value string;
attribute incremental_id, value string;

# ── DI provision-level flags ────────────────────────────────────────────────
attribute di_covenant_exists, value boolean;
attribute has_separate_secured_covenant, value boolean;
attribute has_separate_unsecured_covenant, value boolean;
attribute unlimited_ratio_debt_detected, value boolean;
attribute ied_avoids_mfn_detected, value boolean;
attribute basket_stacking_risk_detected, value boolean;
attribute trapdoor_basket_detected, value boolean;

# ── DI reference entity attributes ──────────────────────────────────────────
attribute numerator_formula, value string;
attribute denominator_formula, value string;
attribute comparison_operator, value string;          # <= | >=
attribute is_financial_test, value boolean;
attribute is_structural, value boolean;
attribute rank, value integer;
attribute is_term, value boolean;
attribute is_revolving, value boolean;
attribute is_incremental, value boolean;

# ── DI incremental facility attributes ──────────────────────────────────────
attribute free_and_clear_amount_usd, value double;
attribute free_and_clear_pct_ebitda, value double;
attribute free_and_clear_is_grower, value boolean;
attribute prepayments_prong_exists, value boolean;
attribute prepayments_includes_junior, value boolean;
attribute prepayments_includes_buybacks, value boolean;
attribute ratio_prong_exists, value boolean;
attribute ratio_prong_threshold, value double;
attribute ratio_prong_test_type, value string;
attribute ratio_prong_unlimited, value boolean;
attribute ied_permitted, value boolean;
attribute ied_triggers_mfn, value boolean;
attribute ied_requires_intercreditor, value boolean;
attribute mfn_threshold_bps, value integer;
attribute mfn_sunset_months, value integer;
attribute mfn_excludes_freebie, value boolean;
attribute mfn_excludes_acquisitions, value boolean;
attribute mfn_excludes_maturity_outside, value boolean;
attribute reclassification_permitted, value boolean;
attribute reclassification_automatic, value boolean;
attribute reclassification_bidirectional, value boolean;

# ── DI basket attributes ────────────────────────────────────────────────────
attribute basket_cap_usd, value double;
attribute basket_cap_pct_ebitda, value double;
attribute is_grower, value boolean;
attribute permits_secured, value boolean;
attribute permits_unsecured, value boolean;
attribute requires_pro_forma_ratio, value boolean;
attribute pro_forma_threshold, value double;

# ── DI leverage tier attributes ─────────────────────────────────────────────
attribute tier_number, value integer;
attribute leverage_floor, value double;
attribute leverage_ceiling, value double;
attribute capacity_usd, value double;
attribute capacity_pct_ebitda, value double;
attribute is_unlimited, value boolean;

# ── DI relation attributes ──────────────────────────────────────────────────
attribute threshold_value, value double;
attribute is_incurrence_test, value boolean;
attribute is_mandatory, value boolean;
attribute is_maximum, value boolean;
attribute reduction_is_permanent, value boolean;
attribute pool_name, value string;
attribute triggers_for_term_loans, value boolean;
attribute triggers_for_revolvers, value boolean;
attribute triggers_for_ied, value boolean;
attribute freebie_exempt_usd, value double;
attribute shares_capacity, value boolean;
attribute max_lien_priority, value string;
attribute is_dollar_for_dollar, value boolean;

# ── DI provision-level scalars (Phase 2) ────────────────────────────────────
attribute addback_cap_pct, value double;
attribute addbacks_capped, value boolean;
attribute aggregate_secured_lien_cap, value double;
attribute asset_sale_reloads_incremental, value boolean;
attribute auto_lien_permission, value boolean;
attribute basket_arbitrage_detected, value boolean;
attribute basket_reload_on_prepayment, value boolean;
attribute blocker_eod_only, value boolean;
attribute blocker_payment_bankruptcy_only, value boolean;
attribute builder_repayment_reloads_debt, value boolean;
attribute contribution_debt_builds_rp, value boolean;
attribute contribution_rp_dollar_for_dollar, value boolean;
attribute cross_covenant_basket_sharing, value boolean;
attribute debt_lien_capacity_shared, value boolean;
attribute default_blocker_scope, value string;
attribute freebie_ratio_stacking_permitted, value boolean;
attribute general_basket_has_lien_basket, value boolean;
attribute grower_basket_count, value integer;
attribute has_sublimit_baskets, value boolean;
attribute incremental_has_lien_basket, value boolean;
attribute indebtedness_definition_broad, value boolean;
attribute intercompany_leakage_risk, value boolean;
attribute liens_covenant_section, value string;
attribute max_first_lien_capacity_usd, value double;
attribute max_total_capacity_usd, value double;
attribute mfn_sunset_expired, value boolean;
attribute no_worse_test_detected, value boolean;
attribute outside_collateral_liens_permitted, value boolean;
attribute pro_forma_includes_synergies, value boolean;
attribute ratio_debt_has_lien_basket, value boolean;
attribute ratios_first_ordering, value boolean;
attribute rp_to_debt_conversion_permitted, value boolean;
attribute structural_seniority_risk, value boolean;
attribute synergies_require_expectation, value boolean;
attribute synergy_cap_pct, value double;
attribute total_freebie_capacity_usd, value double;
attribute unlimited_reclass_detected, value boolean;
attribute unsub_redesignation_permitted, value boolean;
attribute unsub_unlimited_debt, value boolean;
attribute uses_first_lien_leverage, value boolean;
attribute uses_fixed_charge_coverage, value boolean;
attribute uses_interest_coverage, value boolean;
attribute uses_senior_secured_leverage, value boolean;
attribute uses_total_leverage, value boolean;
attribute vulnerability_notes, value string;

# ── DI incremental facility scalars (Phase 2) ──────────────────────────────
attribute agent_consent_nurd, value boolean;
attribute amortization_permitted, value boolean;
attribute amortization_prohibited, value boolean;
attribute basket_splitting_permitted, value boolean;
attribute binds_borrower, value boolean;
attribute binds_guarantors, value boolean;
attribute collateral_parity_required, value boolean;
attribute contribution_multiplier, value double;
attribute currency_matching_required, value boolean;
attribute freebie_excluded_from_ratio, value boolean;
attribute freebie_refresh_permitted, value boolean;
attribute general_basket_addable, value boolean;
attribute guarantor_parity_required, value boolean;
attribute ied_covenant_parity, value boolean;
attribute ied_junior_lien_permitted, value boolean;
attribute ied_maturity_restriction, value boolean;
attribute ied_permitted_forms, value string;
attribute ied_permitted_incurrors, value string;
attribute ied_shares_cap, value boolean;
attribute ied_unsecured_permitted, value boolean;
attribute lct_max_concurrent, value integer;
attribute lct_permitted, value boolean;
attribute lender_participation_voluntary, value boolean;
attribute maturity_91_day_inside_permitted, value boolean;
attribute maturity_inside_permitted, value boolean;
attribute maturity_restriction_applies, value boolean;
attribute mfn_applies, value boolean;
attribute mfn_de_minimis_amount, value double;
attribute mfn_excludes_arranger_fees, value boolean;
attribute mfn_excludes_fixed_rate, value boolean;
attribute mfn_includes_floors, value boolean;
attribute mfn_includes_oid, value boolean;
attribute mfn_includes_upfront_fees, value boolean;
attribute mfn_maturity_exclusion_months, value integer;
attribute mfn_oid_amortization_years, value integer;
attribute mfn_uses_all_in_yield, value boolean;
attribute minimum_tranche_size, value double;
attribute notional_cap_usd, value double;
attribute permits_revolving, value boolean;
attribute permits_term_loans, value boolean;
attribute permitted_premium_pct, value double;
attribute ratio_prong_first_lien_threshold, value double;
attribute ratio_prong_total_threshold, value double;
attribute reclassification_limited, value boolean;
attribute reclassification_mfn_applies, value boolean;
attribute reclassification_requires_notice, value boolean;
attribute reclassification_type, value string;
attribute requires_covenant_parity, value boolean;
attribute requires_no_eod_only, value boolean;
attribute requires_subordination, value boolean;
attribute requires_wal_parity, value boolean;
attribute wal_restriction_applies, value boolean;

# ── MFN entity types ─────────────────────────────────────────────────────────

entity mfn_exclusion,
    owns exclusion_id @key,
    owns exclusion_type,
    owns exclusion_has_cap,
    owns exclusion_cap_usd,
    owns exclusion_cap_pct_ebitda,
    owns exclusion_conditions,
    owns can_stack_with_other_exclusions,
    owns excludes_from_mfn,
    owns exclusion_scope,
    owns applies_when,
    owns section_reference,
    owns source_page,
    owns source_text,
    owns confidence,
    plays provision_has_exclusion:exclusion;

entity mfn_yield_definition,
    owns yield_def_id @key,
    owns defined_term,
    owns includes_margin,
    owns includes_floor_benefit,
    owns includes_oid,
    owns includes_upfront_fees,
    owns includes_commitment_fees,
    owns includes_other_fees,
    owns oid_amortization_method,
    owns oid_amortization_years,
    owns comparison_baseline,
    owns differentiates_fixed_floating,
    owns yield_determination_authority,
    owns yield_recalculated_at_incurrence,
    owns reference_rate_changes_affect_yield,
    owns market_price_affects_yield,
    owns section_reference,
    owns source_page,
    owns source_text,
    owns confidence,
    plays provision_has_yield_def:yield_def;

entity mfn_sunset_provision,
    owns sunset_id @key,
    owns sunset_exists,
    owns sunset_period_months,
    owns sunset_trigger_event,
    owns sunset_resets_on_refi,
    owns sunset_tied_to_maturity,
    owns sunset_timing_loophole,
    owns section_reference,
    owns source_page,
    owns source_text,
    owns confidence,
    plays provision_has_sunset:sunset;

entity mfn_freebie_basket,
    owns freebie_id @key,
    owns dollar_amount_usd,
    owns ebitda_pct,
    owns uses_greater_of,
    owns stacks_with_general_basket,
    owns general_basket_amount_usd,
    owns total_mfn_exempt_capacity_usd,
    owns section_reference,
    owns source_page,
    owns source_text,
    owns confidence,
    plays provision_has_freebie:freebie;

# ── MFN entity relations ─────────────────────────────────────────────────────

relation provision_has_exclusion sub provision_has_extracted_entity,
    relates provision,
    relates exclusion as extracted;

relation provision_has_yield_def sub provision_has_extracted_entity,
    relates provision,
    relates yield_def as extracted;

relation provision_has_sunset sub provision_has_extracted_entity,
    relates provision,
    relates sunset as extracted;

relation provision_has_freebie sub provision_has_extracted_entity,
    relates provision,
    relates freebie as extracted;


################################################################################
# §4  CONCEPT TYPE HIERARCHY (for multiselect questions)
#
#   Each subtype of concept represents a closed set of options.
#   Seed data (concept instances) loaded from ontology data files.
#   Claude selects from the closed set during extraction.
#
#   REMOVED (superseded by entities):
#     builder_source      → builder_basket_source entity subtypes (§3)
#     reallocatable_basket → basket_reallocation entity (§3)
#     rdp_basket_type      → rdp_basket entity subtypes (§3)
################################################################################

entity concept @abstract,
    owns concept_id @key,
    owns name,
    owns description,
    owns display_order,
    owns target_entity_type,
    owns target_entity_attribute @card(0..),
    plays concept_applicability:concept,
    plays concept_hierarchy:parent,
    plays concept_hierarchy:child;

# ── MFN concept types ────────────────────────────────────────────────────────

entity facility_prong sub concept;
entity yield_component sub concept;
entity fee_exclusion sub concept;
entity lien_priority sub concept;
entity governance_concept sub concept;
entity sunset_type sub concept;
entity covered_person sub concept;
entity repurchase_trigger sub concept;
entity loophole_type sub concept;
entity protection_type sub concept;

# ── RP concept types ─────────────────────────────────────────────────────────

entity dividend_definition_element sub concept;
entity ip_type sub concept,
    plays blocker_covers_ip_type:ip_type;
entity transfer_type sub concept;
entity blocker_binding_entity sub concept;
entity blocker_timing sub concept;
entity investment_basket sub concept;
entity default_type sub concept;
entity reallocation_target sub concept;

# ── RP expanded concept types ────────────────────────────────────────────────

entity builder_reduction_type sub concept;
entity intercompany_recipient_type sub concept;
entity tax_group_type sub concept;
entity overhead_cost_type sub concept;
entity transaction_cost_type sub concept;
entity equity_award_type sub concept;
entity rdp_payment_type sub concept;
entity reallocation_reduction_type sub concept;
entity exempt_sale_type sub concept;
entity unsub_distribution_condition sub concept;
entity ratio_required_basket sub concept;
entity no_default_basket sub concept;


################################################################################
# §5  ONTOLOGY SYSTEM
################################################################################

attribute extraction_context_sections, value string;
attribute extraction_batch_hint, value string;
attribute synthesis_guidance, value string;

entity ontology_category,
    owns category_id @key,
    owns name,
    owns description,
    owns display_order,
    owns extraction_context_sections,
    owns extraction_batch_hint,
    owns synthesis_guidance,
    plays category_has_question:category,
    plays category_hierarchy:parent_category,
    plays category_hierarchy:child_category;

entity ontology_question,
    owns question_id @key,
    owns question_number,
    owns question_text,
    owns description,
    owns answer_type,
    owns ui_display_type,
    owns is_required,
    owns default_value,
    owns display_order,
    owns covenant_type,
    owns extraction_prompt,
    owns storage_value_type,
    owns target_entity_type,
    owns target_relation_type,
    plays category_has_question:question,
    plays question_targets_field:question,
    plays question_targets_concept:question,
    plays question_targets_entity:question,
    plays question_annotates_attribute:question,
    plays provision_has_answer:question;

# ─── Document Segmentation ──────────────────────────────────────────────────

entity document_segment_type,
    owns segment_type_id @key,
    owns name,
    owns find_description,
    owns display_order,
    owns rp_universe_field,
    owns mfn_universe_field,
    owns di_universe_field;

entity attribute_provenance,
    owns attributed_field_name,
    owns source_text,
    owns source_page,
    owns source_section,
    owns confidence,
    owns extracted_at,
    plays has_provenance:provenance;

entity comparison_set,
    owns name,
    owns description,
    owns created_at,
    plays comparison_includes_deal:comparison;

entity benchmark,
    owns question_id,
    owns benchmark_value_double,
    owns benchmark_value_boolean_pct,
    owns sample_size,
    owns as_of_date;


################################################################################
# §6  QUALIFICATION & CITATION
################################################################################

entity qualification,
    owns qualification_id @key,
    owns qualification_type,
    owns description,
    owns source_text,
    owns source_page,
    plays answer_has_qualification:qualification;

entity source_citation,
    owns citation_id @key,
    owns source_text,
    owns source_page,
    owns citation_context,
    plays answer_has_citation:citation;


################################################################################
# §7  RELATIONS
################################################################################

# ─── Core ─────────────────────────────────────────────────────────────────────

relation deal_has_document,
    relates deal,
    relates document;

relation deal_has_provision,
    relates deal,
    relates provision;

relation comparison_includes_deal,
    relates comparison,
    relates deal;

# ─── Concept system ──────────────────────────────────────────────────────────

relation concept_hierarchy,
    relates parent,
    relates child;

relation category_hierarchy,
    relates parent_category,
    relates child_category;

relation concept_applicability,
    relates provision,
    relates concept,
    owns applicability_status,
    owns source_text,
    owns source_page,
    owns source_section,
    owns confidence;

# ─── Ontology question targeting ──────────────────────────────────────────────
#
#   Three channels — one per answer_type family:
#
#   Channel 1 (SCALAR):
#     question_targets_field → provision_has_answer relation
#     target_field_name identifies the answer for API consumers.
#     The typed value lives on provision_has_answer (answer_boolean, etc.).
#
#   Channel 2 (MULTISELECT):
#     question_targets_concept → concept_applicability relation
#     Claude selects from closed set of seed concept instances.
#
#   Channel 3 (ENTITY):
#     question_targets_entity → typed entity instances + relation
#     Pipeline introspects entity's owns → builds prompt fields →
#     Claude returns JSON array → pipeline creates entities + relations.

relation category_has_question,
    relates category,
    relates question;

relation question_targets_field,
    relates question,
    owns target_field_name,
    owns target_entity_type;

relation question_targets_concept,
    relates question,
    owns target_concept_type;

relation question_targets_entity,
    relates question,
    owns target_entity_type,
    owns target_relation_type;

# Maps an ontology question to a Channel 3 entity attribute it annotates.
# Used by graph_reader to append → annotations at display time.
# Replaces the hardcoded ATTRIBUTE_GLOSSARY in attribute_glossary.py.
relation question_annotates_attribute,
    relates question,
    owns target_entity_type,
    owns target_attribute_name;

# ─── Answer storage ──────────────────────────────────────────────────────────
#
#   THE canonical store for all scalar extracted values.
#   One relation instance per (provision, question) pair.
#   answer_* attributes carry the typed value.

relation provision_has_answer,
    relates provision,
    relates question,
    owns answer_id @key,
    owns answer_boolean,
    owns answer_integer,
    owns answer_double,
    owns answer_string,
    owns answer_date,
    owns source_text,
    owns source_page,
    owns source_section,
    owns confidence,
    owns extracted_at;

# ─── Provenance ──────────────────────────────────────────────────────────────

relation has_provenance,
    relates attributed_entity,
    relates provenance;

# ─── Qualification & Citation ─────────────────────────────────────────────────

relation answer_has_qualification,
    relates qualified_answer,
    relates qualification;

relation answer_has_citation,
    relates cited_answer,
    relates citation;

relation provision_cross_reference,
    relates source_provision,
    relates target_provision,
    owns cross_reference_type,
    owns cross_reference_explanation,
    owns source_text,
    owns source_page;

# ─── Entity relations ────────────────────────────────────────────────────────
#
#   Created by Channel 3 (answer_type = "entity") questions.
#   question_targets_entity.target_relation_type maps to these:
#
#     "provision_has_basket"        → provision_has_basket
#     "basket_has_source"           → basket_has_source
#     "provision_has_rdp_basket"    → provision_has_rdp_basket
#     "provision_has_blocker"       → provision_has_blocker
#     "blocker_has_exception"       → blocker_has_exception
#     "provision_has_unsub"         → provision_has_unsub
#     "provision_has_sweep_tier"    → provision_has_sweep_tier
#     "provision_has_sweep_exemption" → provision_has_sweep_exemption
#     "provision_has_de_minimis"    → provision_has_de_minimis
#     "provision_has_reallocation"  → provision_has_reallocation
#     "provision_has_pathway"       → provision_has_pathway

# Abstract parent for all provision → extracted entity relations.
# Enables polymorphic fetch: one query returns all entity types via (provision: $p, extracted: $e).
# Each child keeps its own `relates provision` and aliases its entity role as `extracted`.
relation provision_has_extracted_entity @abstract,
    relates extracted;

relation provision_has_basket sub provision_has_extracted_entity,
    relates provision,
    relates basket as extracted;

# Abstract parent for entity→child relations.
# Positive marker for parent-child relationships within the entity graph.
# Used by polymorphic fetch to distinguish children from peer cross-references.
relation entity_has_child @abstract,
    relates parent,
    relates child;

# basket_has_source REMOVED — builder sources flattened onto builder_basket

relation provision_has_rdp_basket sub provision_has_extracted_entity,
    relates provision,
    relates rdp_basket as extracted;

relation provision_has_blocker sub provision_has_extracted_entity,
    relates provision,
    relates blocker as extracted;

relation blocker_has_exception sub entity_has_child,
    relates blocker as parent,
    relates exception as child;

relation blocker_covers_ip_type,
    relates blocker,
    relates ip_type,
    owns coverage_scope;

relation provision_has_unsub sub provision_has_extracted_entity,
    relates provision,
    relates designation as extracted;

relation provision_has_sweep_tier sub provision_has_extracted_entity,
    relates provision,
    relates tier as extracted;

relation provision_has_asset_sale_sweep sub provision_has_extracted_entity,
    relates provision,
    relates sweep as extracted;

# provision_has_sweep_exemption REMOVED — exemptions are booleans on asset_sale_sweep
# provision_has_de_minimis REMOVED — thresholds are attrs on asset_sale_sweep
# provision_has_reallocation REMOVED — use basket_reallocates_to relation instead

relation provision_has_pathway sub provision_has_extracted_entity,
    relates provision,
    relates pathway as extracted;

relation basket_reallocates_to,
    relates source_basket,
    relates target_basket,
    owns reallocation_source,
    owns reallocation_amount_usd,
    owns reallocation_grower_pct,
    owns is_bidirectional,
    owns reduces_source_basket,
    owns reduction_is_dollar_for_dollar,
    owns reduction_while_outstanding_only,
    owns section_reference,
    owns source_page,
    owns source_text,
    owns confidence,
    owns capacity_effect;

relation shares_capacity_pool,
    relates pool_member;

# ─── New cross-document relations ──────────────────────────────────────────────

relation provision_has_intercompany_permission sub provision_has_extracted_entity,
    relates provision,
    relates permission as extracted;

relation provision_has_definition sub provision_has_extracted_entity,
    relates provision,
    relates definition as extracted;

relation provision_has_lien_release sub provision_has_extracted_entity,
    relates provision,
    relates lien_release as extracted;

relation has_amendment_threshold sub provision_has_extracted_entity,
    relates entity_with_threshold,
    relates threshold as extracted;

# ═══════════════════════════════════════════════════════════════════════════════
# EXTRACTION METADATA (SSoT for Claude prompts)
#
#   Each instance describes one extraction task: what entity to extract,
#   which prompt to use, section hints, and priority ordering.
# ═══════════════════════════════════════════════════════════════════════════════

attribute metadata_id, value string;
attribute extraction_section_hint, value string;
attribute extraction_priority, value integer;
attribute target_attribute, value string;
attribute requires_context, value boolean;
attribute context_entities, value string;

entity extraction_metadata,
    owns metadata_id @key,
    owns target_entity_type,
    owns target_attribute,
    owns extraction_prompt,
    owns extraction_section_hint,
    owns extraction_priority,
    owns requires_context,
    owns context_entities;

# ═══════════════════════════════════════════════════════════════════════════════
# SWEEP EXEMPTION TYPES
# ═══════════════════════════════════════════════════════════════════════════════

attribute exemption_id, value string;
attribute exemption_name, value string;

# sweep_exemption hierarchy REMOVED — exemptions are boolean flags on asset_sale_sweep
# (exempt_non_collateral, exempt_ordinary_course, exempt_casualty,
#  exempt_below_threshold, exempt_ratio_basket)




################################################################################
# §10  J.CREW CONCEPT TYPES (multiselect)
################################################################################

entity blocker_prohibition_type sub concept;

entity blocker_carveout_type sub concept;

entity covered_entity_type sub concept;

entity protected_asset_type sub concept;

entity investment_basket_type sub concept;

entity designation_condition_type sub concept;

entity ip_inclusion_type sub concept;

entity transfer_inclusion_type sub concept;

entity material_definition_method sub concept;

entity material_threshold_basis sub concept;

# ══════════════════════════════════════════════════════════════════════════════
# J.Crew data flows through the SAME channels as RP/MFN:
#   Scalar answers → provision_has_answer (question_ids: jc_t1_*, jc_t2_*, jc_t3_*)
#   Multiselect   → concept_applicability (blocker_prohibition_type, etc.)
#   Provision     → rp_provision (JC data attaches to the RP provision)
# ══════════════════════════════════════════════════════════════════════════════


################################################################################
# §11  DEBT INCURRENCE (DI)
#
#   Models the debt incurrence negative covenant in credit agreements.
#   Covers: incremental facilities, permitted debt baskets, ratio tests,
#   leverage tiers, and cross-covenant links to MFN/RP.
#
#   Data flows through the SAME three channels as RP/MFN:
#     Channel 1: provision_has_answer    → scalar answers
#     Channel 2: concept_applicability   → multiselect
#     Channel 3: typed entities          → structured (below)
################################################################################

# ── DI Reference Entities (seeded once, shared across deals) ────────────────

entity ratio_test_type,
    owns ratio_test_type_id @key,
    owns name,
    owns numerator_formula,
    owns denominator_formula,
    owns comparison_operator,
    owns description,
    plays basket_uses_ratio_test:ratio_test,
    plays tier_uses_ratio_test:ratio_test;

entity debt_condition_type,
    owns condition_type_id @key,
    owns name,
    owns is_financial_test,
    owns is_structural,
    owns description,
    plays basket_requires_condition:condition;

entity di_lien_priority,
    owns priority_id @key,
    owns name,
    owns rank,
    owns description,
    plays basket_permits_lien:priority;

entity di_facility_type,
    owns facility_type_id @key,
    owns name,
    owns is_term,
    owns is_revolving,
    owns is_incremental,
    plays incremental_permits_facility:fac_type;

# ── DI Provision (pure anchor — owns only computed flags) ───────────────────

entity di_provision sub provision,
    # DI1: Core Structure
    owns di_covenant_exists,
    owns binds_borrower,
    owns binds_guarantors,
    owns binds_restricted_subs,
    owns has_separate_secured_covenant,
    owns has_separate_unsecured_covenant,
    owns indebtedness_definition_broad,
    # DI6: Ratio Tests
    owns uses_first_lien_leverage,
    owns uses_total_leverage,
    owns uses_senior_secured_leverage,
    owns uses_interest_coverage,
    owns uses_fixed_charge_coverage,
    owns ratios_first_ordering,
    owns pro_forma_includes_synergies,
    owns synergies_require_expectation,
    owns synergy_cap_pct,
    owns addbacks_capped,
    owns addback_cap_pct,
    owns lct_permitted,
    owns lct_max_concurrent,
    owns no_worse_test_detected,
    # DI7: Conditions
    owns default_blocker_scope,
    owns blocker_eod_only,
    owns blocker_payment_bankruptcy_only,
    # DI9: Liens Correlation
    owns incremental_has_lien_basket,
    owns ratio_debt_has_lien_basket,
    owns general_basket_has_lien_basket,
    owns debt_lien_capacity_shared,
    owns liens_covenant_section,
    owns outside_collateral_liens_permitted,
    owns auto_lien_permission,
    owns aggregate_secured_lien_cap,
    # DI10: Cross-Covenant Links
    owns contribution_debt_builds_rp,
    owns contribution_rp_dollar_for_dollar,
    owns asset_sale_reloads_incremental,
    owns rp_to_debt_conversion_permitted,
    owns cross_covenant_basket_sharing,
    # DI11: Capacity Calculation
    owns total_freebie_capacity_usd,
    owns max_first_lien_capacity_usd,
    owns max_total_capacity_usd,
    owns grower_basket_count,
    owns has_sublimit_baskets,
    owns basket_reload_on_prepayment,
    owns builder_repayment_reloads_debt,
    owns unsub_redesignation_permitted,
    owns unsub_unlimited_debt,
    owns freebie_ratio_stacking_permitted,
    owns mfn_sunset_expired,
    # DI12: Vulnerabilities (pattern flags)
    owns trapdoor_basket_detected,
    owns unlimited_ratio_debt_detected,
    owns ied_avoids_mfn_detected,
    owns basket_stacking_risk_detected,
    owns basket_arbitrage_detected,
    owns unlimited_reclass_detected,
    owns structural_seniority_risk,
    owns intercompany_leakage_risk,
    owns vulnerability_notes,
    # Relations
    plays provision_has_incremental:provision,
    plays provision_has_di_basket:provision,
    plays provision_has_leverage_tier:provision,
    plays di_provision_links_mfn:di_prov,
    plays di_provision_links_rp:di_prov;

# ── Incremental Facility (single-instance entity per provision) ─────────────

entity incremental_facility,
    owns incremental_id @key,
    # DI2: Free-and-clear prong
    owns free_and_clear_amount_usd,
    owns free_and_clear_pct_ebitda,
    owns free_and_clear_is_grower,
    # DI2: Prepayments prong
    owns prepayments_prong_exists,
    owns prepayments_includes_junior,
    owns prepayments_includes_buybacks,
    # DI2: Ratio prong
    owns ratio_prong_exists,
    owns ratio_prong_threshold,
    owns ratio_prong_test_type,
    owns ratio_prong_unlimited,
    owns ratio_prong_first_lien_threshold,
    owns ratio_prong_total_threshold,
    # DI2: Incremental conditions
    owns general_basket_addable,
    owns freebie_excluded_from_ratio,
    owns requires_no_default,
    owns requires_no_eod_only,
    owns maturity_restriction_applies,
    owns maturity_inside_permitted,
    owns maturity_91_day_inside_permitted,
    owns wal_restriction_applies,
    owns requires_wal_parity,
    owns amortization_prohibited,
    owns amortization_permitted,
    owns requires_covenant_parity,
    owns collateral_parity_required,
    owns guarantor_parity_required,
    owns currency_matching_required,
    owns permits_term_loans,
    owns permits_revolving,
    owns agent_consent_nurd,
    owns minimum_tranche_size,
    owns lender_participation_voluntary,
    owns basket_splitting_permitted,
    owns lct_permitted,
    # DI3: MFN linkage
    owns mfn_applies,
    owns mfn_threshold_bps,
    owns mfn_uses_all_in_yield,
    owns mfn_sunset_months,
    owns mfn_excludes_freebie,
    owns mfn_excludes_acquisitions,
    owns mfn_excludes_maturity_outside,
    owns mfn_maturity_exclusion_months,
    owns mfn_excludes_arranger_fees,
    owns mfn_excludes_fixed_rate,
    owns mfn_includes_floors,
    owns mfn_includes_oid,
    owns mfn_includes_upfront_fees,
    owns mfn_oid_amortization_years,
    owns mfn_de_minimis_amount,
    owns mfn_sunset_expired,
    owns freebie_refresh_permitted,
    # DI4: IED (Incremental Equivalent Debt)
    owns ied_permitted,
    owns ied_shares_cap,
    owns ied_triggers_mfn,
    owns ied_requires_intercreditor,
    owns ied_permitted_forms,
    owns ied_permitted_incurrors,
    owns ied_maturity_restriction,
    owns ied_covenant_parity,
    owns ied_junior_lien_permitted,
    owns ied_unsecured_permitted,
    # DI8: Reclassification
    owns reclassification_permitted,
    owns reclassification_automatic,
    owns reclassification_bidirectional,
    owns reclassification_type,
    owns reclassification_limited,
    owns reclassification_mfn_applies,
    owns reclassification_requires_notice,
    # Provenance
    owns section_reference,
    owns source_page,
    owns source_text,
    owns confidence,
    # Relations
    plays provision_has_incremental:incremental,
    plays incremental_triggers_mfn:incremental,
    plays incremental_permits_facility:incremental;

# ── DI Basket Hierarchy ─────────────────────────────────────────────────────

entity di_basket @abstract,
    owns basket_id @key,
    owns display_name,
    owns basket_cap_usd,
    owns basket_cap_pct_ebitda,
    owns is_grower,
    owns permits_secured,
    owns permits_unsecured,
    owns requires_pro_forma_ratio,
    owns pro_forma_threshold,
    owns is_unlimited_if_met,
    owns default_condition,
    owns requires_ratio_test,
    owns capacity_category,
    # Provenance
    owns section_reference,
    owns source_page,
    owns source_text,
    owns confidence,
    # Relations
    plays provision_has_di_basket:di_basket,
    plays basket_uses_ratio_test:basket,
    plays basket_requires_condition:basket,
    plays basket_permits_lien:basket,
    plays di_shares_capacity_pool:pool_member,
    plays basket_reduces_basket:source_basket,
    plays basket_reduces_basket:target_basket;

# 20 concrete basket subtypes
entity credit_agreement_basket sub di_basket;
entity incremental_basket sub di_basket;
entity ratio_debt_basket sub di_basket,
    owns ratio_threshold;
entity general_basket sub di_basket;
entity acquisition_basket sub di_basket;
entity capital_lease_basket sub di_basket;
entity purchase_money_basket sub di_basket;
entity intercompany_basket sub di_basket,
    owns requires_subordination;
entity refinancing_basket sub di_basket,
    owns permitted_premium_pct;
entity hedging_basket sub di_basket,
    owns notional_cap_usd;
entity lc_basket sub di_basket;
entity sale_leaseback_basket sub di_basket;
entity foreign_subsidiary_basket sub di_basket;
entity earnout_basket sub di_basket;
entity working_capital_basket sub di_basket;
entity contribution_basket sub di_basket,
    owns contribution_multiplier,
    plays di_feeds_rp_builder:contrib;
entity ied_basket sub di_basket;
entity non_guarantor_basket sub di_basket;
entity ratio_secured_basket sub di_basket;
entity ratio_unsecured_basket sub di_basket;

# ── Leverage Tier (entity_list — multiple per provision) ────────────────────

entity leverage_tier,
    owns tier_id @key,
    owns tier_number,
    owns leverage_floor,
    owns leverage_ceiling,
    owns capacity_usd,
    owns capacity_pct_ebitda,
    owns is_unlimited,
    # Provenance
    owns section_reference,
    owns source_page,
    owns source_text,
    owns confidence,
    # Relations
    plays provision_has_leverage_tier:tier,
    plays tier_uses_ratio_test:tier;

# ── DI Entity Relations (sub provision_has_extracted_entity) ────────────────
#    Enables polymorphic fetch via abstract parent query.

relation provision_has_incremental sub provision_has_extracted_entity,
    relates provision,
    relates incremental as extracted;

relation provision_has_di_basket sub provision_has_extracted_entity,
    relates provision,
    relates di_basket as extracted;

relation provision_has_leverage_tier sub provision_has_extracted_entity,
    relates provision,
    relates tier as extracted;

# ── DI Structural Relations (entity-to-reference joins) ─────────────────────

relation basket_uses_ratio_test,
    relates basket,
    relates ratio_test,
    owns threshold_value,
    owns is_incurrence_test;

relation basket_requires_condition,
    relates basket,
    relates condition,
    owns is_mandatory;

relation basket_permits_lien,
    relates basket,
    relates priority,
    owns is_maximum;

relation basket_reduces_basket,
    relates source_basket,
    relates target_basket,
    owns reduction_is_permanent;

relation di_shares_capacity_pool,
    relates pool_member,
    owns pool_name;

relation incremental_permits_facility,
    relates incremental,
    relates fac_type;

relation tier_uses_ratio_test,
    relates tier,
    relates ratio_test,
    owns threshold_value,
    owns is_incurrence_test;

# ── DI Cross-Covenant Relations ─────────────────────────────────────────────

relation incremental_triggers_mfn,
    relates incremental,
    relates mfn_prov,
    owns triggers_for_term_loans,
    owns triggers_for_revolvers,
    owns triggers_for_ied,
    owns freebie_exempt_usd,
    owns mfn_sunset_months;

relation di_provision_links_mfn,
    relates di_prov,
    relates mfn_prov;

relation di_provision_links_rp,
    relates di_prov,
    relates rp_prov;

relation di_feeds_rp_builder,
    relates contrib,
    relates builder,
    owns is_dollar_for_dollar;

# ══════════════════════════════════════════════════════════════════════════════
# DI data flows through the SAME channels as RP/MFN:
#   Scalar answers → provision_has_answer (question_ids: di_*)
#   Multiselect   → concept_applicability
#   Typed entities → provision_has_incremental, provision_has_di_basket,
#                    provision_has_leverage_tier
#   Provision     → di_provision
# ══════════════════════════════════════════════════════════════════════════════

# ── Builder basket source attrs (flattened onto builder_basket) ──────────────
attribute has_starter_amount_source, value boolean;
attribute has_cni_source, value boolean;
attribute has_ecf_source, value boolean;
attribute has_ebitda_fc_source, value boolean;
attribute has_equity_proceeds_source, value boolean;
attribute has_asset_proceeds_source, value boolean;
attribute has_investment_returns_source, value boolean;
attribute has_debt_conversion_source, value boolean;
attribute starter_dollar_amount, value double;
attribute starter_ebitda_pct, value double;
attribute starter_uses_greater_of, value boolean;
attribute cni_percentage, value double;
attribute cni_is_primary_test, value boolean;

# Question: rp_k7 "Which types of transfers are restricted by the blocker?"
# ═══════════════════════════════════════════════════════════════════════════════

match $c isa transfer_type, has concept_id "assignment";
insert $c has target_entity_type "jcrew_blocker", has target_entity_attribute "covers_assignment";

match $c isa transfer_type, has concept_id "sale";
insert $c has target_entity_type "jcrew_blocker", has target_entity_attribute "covers_sale";

match $c isa transfer_type, has concept_id "contribution_to_capital";
insert $c has target_entity_type "jcrew_blocker", has target_entity_attribute "covers_contribution_to_capital";

match $c isa transfer_type, has concept_id "exclusive_license";
insert $c has target_entity_type "jcrew_blocker", has target_entity_attribute "covers_exclusive_licensing";

match $c isa transfer_type, has concept_id "non_exclusive_license";
insert $c has target_entity_type "jcrew_blocker", has target_entity_attribute "covers_nonexclusive_licensing";

match $c isa transfer_type, has concept_id "pledge";
insert $c has target_entity_type "jcrew_blocker", has target_entity_attribute "covers_pledge";

match $c isa transfer_type, has concept_id "abandonment";
insert $c has target_entity_type "jcrew_blocker", has target_entity_attribute "covers_abandonment";


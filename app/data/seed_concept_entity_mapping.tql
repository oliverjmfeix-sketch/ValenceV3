################################################################################
# CONCEPT → ENTITY BOOLEAN MAPPING
#
# Maps each concept instance to the entity attribute it should set.
# graph_storage.py reads this at startup to route multiselect answers
# to entity booleans instead of writing concept_applicability.
#
# Pattern: concept_id → (target_entity_type, target_entity_attribute)
# When Claude selects concept_id "X" for question "Y", the storage layer
# sets target_entity_attribute = true on the target_entity_type entity.
#
# Concepts that are SKIPPED (with rationale):
#   - MFN concepts: not part of this migration phase
#   - reallocation_reduction_type: superseded by basket_reallocation entity
#   - reallocation_target: superseded by basket_reallocation entity
#   - exempt_sale_type: superseded by sweep_exemption entity subtypes
#   - investment_basket: maps to entity existence (investment_pathway), not booleans
#   - investment_basket_type (J.Crew): same — entity existence IS the answer
#   - blocker_carveout_type (J.Crew): maps to blocker_exception entity subtypes (already Channel 3)
#   - default_type: no direct entity boolean mapping
#   - loophole_type: no direct entity boolean mapping
#   - protection_type: no direct entity boolean mapping
#   - unsub_distribution_condition: no instances exist yet
#   - ratio_required_basket: maps to basket-level requires_ratio_test, handled differently
#   - no_default_basket: maps to basket-level default_condition, handled differently
################################################################################

# ═══════════════════════════════════════════════════════════════════════════════
# BLOCKER_BINDING_ENTITY → jcrew_blocker booleans
# Question: rp_k4 "Which entities are bound by the J.Crew blocker?"
# ═══════════════════════════════════════════════════════════════════════════════

match $c isa blocker_binding_entity, has concept_id "loan_parties";
insert $c has target_entity_type "jcrew_blocker", has target_entity_attribute "binds_loan_parties";

match $c isa blocker_binding_entity, has concept_id "borrower";
insert $c has target_entity_type "jcrew_blocker", has target_entity_attribute "binds_borrower_only";

match $c isa blocker_binding_entity, has concept_id "guarantors";
insert $c has target_entity_type "jcrew_blocker", has target_entity_attribute "binds_loan_parties";

match $c isa blocker_binding_entity, has concept_id "restricted_subsidiaries";
insert $c has target_entity_type "jcrew_blocker", has target_entity_attribute "binds_restricted_subs";

match $c isa blocker_binding_entity, has concept_id "all_restricted_subs";
insert $c has target_entity_type "jcrew_blocker", has target_entity_attribute "binds_restricted_subs";

match $c isa blocker_binding_entity, has concept_id "non_guarantor_restricted_subs";
insert $c has target_entity_type "jcrew_blocker", has target_entity_attribute "binds_restricted_subs";


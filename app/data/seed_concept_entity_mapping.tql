insert $c has target_entity_type "rp_provision", has target_entity_attribute "rdp_includes_optional_payments";

match $c isa rdp_payment_type, has concept_id "rdp_prepayments";
insert $c has target_entity_type "rp_provision", has target_entity_attribute "rdp_includes_prepayments";

match $c isa rdp_payment_type, has concept_id "rdp_repurchases";
insert $c has target_entity_type "rp_provision", has target_entity_attribute "rdp_includes_open_market_purchases";

match $c isa rdp_payment_type, has concept_id "rdp_redemptions";
insert $c has target_entity_type "rp_provision", has target_entity_attribute "rdp_includes_redemptions";

match $c isa rdp_payment_type, has concept_id "rdp_acquisitions";
insert $c has target_entity_type "rp_provision", has target_entity_attribute "rdp_includes_defeasance";

# ═══════════════════════════════════════════════════════════════════════════════

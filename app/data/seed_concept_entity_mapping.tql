match $c isa dividend_definition_element, has concept_id "dde_declaring";
insert $c has target_entity_type "rp_provision", has target_entity_attribute "includes_cash_dividends";

match $c isa dividend_definition_element, has concept_id "dde_authorizing";
insert $c has target_entity_type "rp_provision", has target_entity_attribute "includes_distributions";

match $c isa dividend_definition_element, has concept_id "dde_returning_capital";
insert $c has target_entity_type "rp_provision", has target_entity_attribute "includes_distributions";

match $c isa dividend_definition_element, has concept_id "dde_redemptions";
insert $c has target_entity_type "rp_provision", has target_entity_attribute "includes_share_buybacks";

match $c isa dividend_definition_element, has concept_id "dde_retirements";
insert $c has target_entity_type "rp_provision", has target_entity_attribute "includes_share_buybacks";

match $c isa dividend_definition_element, has concept_id "dde_purchases";
insert $c has target_entity_type "rp_provision", has target_entity_attribute "includes_share_buybacks";

match $c isa dividend_definition_element, has concept_id "dde_acquisitions";
insert $c has target_entity_type "rp_provision", has target_entity_attribute "includes_share_buybacks";

match $c isa dividend_definition_element, has concept_id "dde_options_warrants";
insert $c has target_entity_type "rp_provision", has target_entity_attribute "includes_share_buybacks";

match $c isa dividend_definition_element, has concept_id "dde_property_delivery";
insert $c has target_entity_type "rp_provision", has target_entity_attribute "includes_distributions";


# ═══════════════════════════════════════════════════════════════════════════════
# BLOCKER_TIMING → jcrew_blocker booleans
# Question: rp_k5 "When does the J.Crew blocker apply?"
# ═══════════════════════════════════════════════════════════════════════════════

match $c isa blocker_timing, has concept_id "bt_at_designation";
insert $c has target_entity_type "jcrew_blocker", has target_entity_attribute "covers_designation";

match $c isa blocker_timing, has concept_id "bt_at_transfer";
insert $c has target_entity_type "jcrew_blocker", has target_entity_attribute "covers_transfer";

# bt_at_both: sets BOTH covers_transfer and covers_designation.
# Single concept → single target_entity_attribute limitation.
# Map to covers_transfer; storage layer must also set covers_designation
# when bt_at_both is selected.
match $c isa blocker_timing, has concept_id "bt_at_both";
insert $c has target_entity_type "jcrew_blocker", has target_entity_attribute "covers_transfer";

# bt_ongoing: continuous covenant, not event-triggered.
# Maps to covers_post_designation (ongoing implies post-designation coverage).
match $c isa blocker_timing, has concept_id "bt_ongoing";
insert $c has target_entity_type "jcrew_blocker", has target_entity_attribute "covers_post_designation";

# ═══════════════════════════════════════════════════════════════════════════════
# COVERED_PERSON → management_equity_basket booleans
# Question: rp_c2 "Which persons are covered by the management equity basket?"
# ═══════════════════════════════════════════════════════════════════════════════

match $c isa covered_person, has concept_id "current_officers";
insert $c has target_entity_type "management_equity_basket", has target_entity_attribute "covers_officers";

match $c isa covered_person, has concept_id "former_officers";
insert $c has target_entity_type "management_equity_basket", has target_entity_attribute "covers_officers";

match $c isa covered_person, has concept_id "current_directors";
insert $c has target_entity_type "management_equity_basket", has target_entity_attribute "covers_directors";

match $c isa covered_person, has concept_id "former_directors";
insert $c has target_entity_type "management_equity_basket", has target_entity_attribute "covers_directors";

match $c isa covered_person, has concept_id "current_employees";
insert $c has target_entity_type "management_equity_basket", has target_entity_attribute "covers_employees";

match $c isa covered_person, has concept_id "former_employees";
insert $c has target_entity_type "management_equity_basket", has target_entity_attribute "covers_employees";

match $c isa covered_person, has concept_id "consultants";
insert $c has target_entity_type "management_equity_basket", has target_entity_attribute "covers_consultants";

match $c isa covered_person, has concept_id "estates";
insert $c has target_entity_type "management_equity_basket", has target_entity_attribute "covers_estates";

# spouses, ex_spouses, heirs, beneficiaries, transferees, family_members:
# No direct entity boolean — these are sub-categories of covered persons
# that don't have dedicated booleans on management_equity_basket.
# They remain as Channel 2 concept_applicability selections.


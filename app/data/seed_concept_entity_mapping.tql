# ═══════════════════════════════════════════════════════════════════════════════
# TRANSACTION_COST_TYPE — no direct entity boolean mapping
# These describe categories of permitted transaction costs (acquisition, disposition,
# financing, IPO) that don't map to booleans on any entity.
# Remain as Channel 2 concept_applicability selections.
# ═══════════════════════════════════════════════════════════════════════════════

# SKIPPED: tct_acquisition, tct_disposition, tct_financing, tct_ipo

# ═══════════════════════════════════════════════════════════════════════════════
# J.CREW CONCEPT TYPES (from jcrew_concepts_seed.tql)
# ═══════════════════════════════════════════════════════════════════════════════

# ── BLOCKER_PROHIBITION_TYPE → jcrew_blocker booleans ────────────────────────
# Question: jc_t1_3 "What specific types of transactions are prohibited?"

match $c isa blocker_prohibition_type, has concept_id "bp_transfer";
insert $c has target_entity_type "jcrew_blocker", has target_entity_attribute "covers_transfer";

match $c isa blocker_prohibition_type, has concept_id "bp_sale";
insert $c has target_entity_type "jcrew_blocker", has target_entity_attribute "covers_sale";

match $c isa blocker_prohibition_type, has concept_id "bp_contribution";
insert $c has target_entity_type "jcrew_blocker", has target_entity_attribute "covers_contribution_to_capital";

match $c isa blocker_prohibition_type, has concept_id "bp_ownership";
insert $c has target_entity_type "jcrew_blocker", has target_entity_attribute "covers_transfer";

match $c isa blocker_prohibition_type, has concept_id "bp_exclusive_license";
insert $c has target_entity_type "jcrew_blocker", has target_entity_attribute "covers_exclusive_licensing";

match $c isa blocker_prohibition_type, has concept_id "bp_nonexclusive_license";
insert $c has target_entity_type "jcrew_blocker", has target_entity_attribute "covers_nonexclusive_licensing";

# bp_any_license covers both exclusive and nonexclusive — map to exclusive
# (stronger prohibition). Storage layer should also set covers_nonexclusive_licensing.
match $c isa blocker_prohibition_type, has concept_id "bp_any_license";
insert $c has target_entity_type "jcrew_blocker", has target_entity_attribute "covers_exclusive_licensing";

match $c isa blocker_prohibition_type, has concept_id "bp_pledge";
insert $c has target_entity_type "jcrew_blocker", has target_entity_attribute "covers_pledge";

match $c isa blocker_prohibition_type, has concept_id "bp_abandonment";
insert $c has target_entity_type "jcrew_blocker", has target_entity_attribute "covers_abandonment";

match $c isa blocker_prohibition_type, has concept_id "bp_sublicense_grant";
insert $c has target_entity_type "jcrew_blocker", has target_entity_attribute "covers_licenses_granted";

# ── BLOCKER_CARVEOUT_TYPE — SKIPPED ──────────────────────────────────────────
# These map to blocker_exception entity subtypes (already Channel 3).
# Entity existence IS the answer — no boolean mapping needed.
# co_ordinary_course, co_fair_value, co_arms_length, co_tax_planning,
# co_intercompany_reorg, co_permitted_asset_sale, co_permitted_investment,
# co_de_minimis, co_non_material_assets, co_non_material

# ── COVERED_ENTITY_TYPE → jcrew_blocker booleans ────────────────────────────
# Question: jc_t1_29 "Which entities are covered by the blocker?"
# Overlaps with blocker_binding_entity but uses different concept_ids.

match $c isa covered_entity_type, has concept_id "ce_loan_parties";
insert $c has target_entity_type "jcrew_blocker", has target_entity_attribute "binds_loan_parties";

match $c isa covered_entity_type, has concept_id "ce_borrower_only";
insert $c has target_entity_type "jcrew_blocker", has target_entity_attribute "binds_borrower_only";

match $c isa covered_entity_type, has concept_id "ce_guarantors";
insert $c has target_entity_type "jcrew_blocker", has target_entity_attribute "binds_loan_parties";

match $c isa covered_entity_type, has concept_id "ce_all_restricted_subs";
insert $c has target_entity_type "jcrew_blocker", has target_entity_attribute "binds_restricted_subs";

match $c isa covered_entity_type, has concept_id "ce_all_group_members";
insert $c has target_entity_type "jcrew_blocker", has target_entity_attribute "binds_holdings";

# ── PROTECTED_ASSET_TYPE → jcrew_blocker booleans ────────────────────────────
# Question: jc_t1_30 "What types of assets are protected?"

match $c isa protected_asset_type, has concept_id "at_registered_ip";
insert $c has target_entity_type "jcrew_blocker", has target_entity_attribute "covers_ip";

match $c isa protected_asset_type, has concept_id "at_all_ip";
insert $c has target_entity_type "jcrew_blocker", has target_entity_attribute "covers_ip";

match $c isa protected_asset_type, has concept_id "at_material_ip";
insert $c has target_entity_type "jcrew_blocker", has target_entity_attribute "covers_material_assets";

match $c isa protected_asset_type, has concept_id "at_material_assets";
insert $c has target_entity_type "jcrew_blocker", has target_entity_attribute "covers_material_assets";

# at_collateral: no direct boolean on jcrew_blocker — remains Channel 2 only.
# SKIPPED: at_collateral

# ── INVESTMENT_BASKET_TYPE — SKIPPED ─────────────────────────────────────────
# These map to entity existence (investment_pathway subtypes), not booleans.
# ib_dedicated_unsub, ib_general_investment, ib_builder_available,
# ib_ratio_based, ib_catch_all

# ── DESIGNATION_CONDITION_TYPE → unsub_designation booleans ──────────────────
# Question: jc_t1_32 "What conditions are required for unsub designation?"

match $c isa designation_condition_type, has concept_id "dc_no_default";
insert $c has target_entity_type "unsub_designation", has target_entity_attribute "requires_no_default";

match $c isa designation_condition_type, has concept_id "dc_board_resolution";
insert $c has target_entity_type "unsub_designation", has target_entity_attribute "requires_board_approval";

# dc_dollar_cap and dc_ebitda_pct_cap map to numeric attributes (dollar_cap_usd,
# pct_cap_assets) not booleans. The concept selection indicates the condition
# EXISTS, but the actual value is captured separately. Map to the attribute
# name for the storage layer to interpret as "this attribute should be populated".
match $c isa designation_condition_type, has concept_id "dc_dollar_cap";
insert $c has target_entity_type "unsub_designation", has target_entity_attribute "dollar_cap_usd";

match $c isa designation_condition_type, has concept_id "dc_ebitda_pct_cap";
insert $c has target_entity_type "unsub_designation", has target_entity_attribute "pct_cap_assets";

# dc_pro_forma_ratio: no direct entity boolean on unsub_designation.
# dc_no_material_ip: no direct entity boolean on unsub_designation.
# These remain as Channel 2 concept_applicability selections for now.
# SKIPPED: dc_pro_forma_ratio, dc_no_material_ip


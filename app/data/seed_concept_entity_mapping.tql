insert $c has target_entity_type "jcrew_blocker", has target_entity_attribute "covers_trademarks";

match $c isa ip_type, has concept_id "service_marks";
insert $c has target_entity_type "jcrew_blocker", has target_entity_attribute "covers_trademarks";

match $c isa ip_type, has concept_id "copyrights";
insert $c has target_entity_type "jcrew_blocker", has target_entity_attribute "covers_copyrights";

match $c isa ip_type, has concept_id "trade_secrets";
insert $c has target_entity_type "jcrew_blocker", has target_entity_attribute "covers_trade_secrets";

match $c isa ip_type, has concept_id "know_how";
insert $c has target_entity_type "jcrew_blocker", has target_entity_attribute "covers_know_how";

match $c isa ip_type, has concept_id "software";
insert $c has target_entity_type "jcrew_blocker", has target_entity_attribute "covers_software";

match $c isa ip_type, has concept_id "domain_names";
insert $c has target_entity_type "jcrew_blocker", has target_entity_attribute "covers_domain_names";

match $c isa ip_type, has concept_id "licenses_received";
insert $c has target_entity_type "jcrew_blocker", has target_entity_attribute "covers_licenses_received";

match $c isa ip_type, has concept_id "customer_lists";
insert $c has target_entity_type "jcrew_blocker", has target_entity_attribute "covers_customer_data";

match $c isa ip_type, has concept_id "databases";
insert $c has target_entity_type "jcrew_blocker", has target_entity_attribute "covers_customer_data";

# ═══════════════════════════════════════════════════════════════════════════════
